@model CapiMovil.PL.Gui.Models.ViewModels.UbicacionBusFormViewModel

@{
    ViewData["Title"] = "Registrar Ubicación";
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card card-soft">
            <div class="card-body">
                <h2 class="page-title mb-4">Registrar Ubicación del Bus</h2>

                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="IdRecorrido" class="form-label"></label>
                        <select asp-for="IdRecorrido" asp-items="Model.Recorridos" class="form-select">
                            <option value="">Seleccione un recorrido</option>
                        </select>
                        <span asp-validation-for="IdRecorrido" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Latitud" class="form-label"></label>
                            <input asp-for="Latitud" class="form-control" />
                            <span asp-validation-for="Latitud" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Longitud" class="form-label"></label>
                            <input asp-for="Longitud" class="form-control" />
                            <span asp-validation-for="Longitud" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Velocidad" class="form-label"></label>
                            <input asp-for="Velocidad" class="form-control" />
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="PrecisionMetros" class="form-label"></label>
                            <input asp-for="PrecisionMetros" class="form-control" />
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="Fuente" class="form-label"></label>
                            <select asp-for="Fuente" asp-items="Model.Fuentes" class="form-select"></select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FechaHora" class="form-label"></label>
                        <input asp-for="FechaHora" class="form-control" />
                        <span asp-validation-for="FechaHora" class="text-danger"></span>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input asp-for="Estado" class="form-check-input" />
                        <label asp-for="Estado" class="form-check-label"></label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Guardar</button>
                        <a asp-action="Listar" class="btn btn-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}