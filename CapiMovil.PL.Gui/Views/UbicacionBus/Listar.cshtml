@model List<CapiMovil.BL.BE.UbicacionBusBE>

@{
    ViewData["Title"] = "Ubicación del Bus";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title mb-1">Operaciones - Ubicación del Bus</h2>
        <p class="text-muted mb-0">Consulta y registra posiciones del bus durante un recorrido.</p>
    </div>
    <a asp-action="Crear" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Nueva Ubicación
    </a>
</div>

<div class="card card-soft shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Recorrido</th>
                        <th>Latitud</th>
                        <th>Longitud</th>
                        <th>Velocidad</th>
                        <th>Precisión</th>
                        <th>Fecha y Hora</th>
                        <th>Fuente</th>
                        <th style="width:160px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.CodigoUbicacion</td>
                                <td>@item.Recorrido?.CodigoRecorrido</td>
                                <td>@item.Latitud</td>
                                <td>@item.Longitud</td>
                                <td>@(item.Velocidad?.ToString() ?? "-")</td>
                                <td>@(item.PrecisionMetros?.ToString() ?? "-")</td>
                                <td>@item.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                                <td><span class="badge bg-info">@item.Fuente</span></td>
                                <td>
                                    <a asp-action="Editar" asp-route-id="@item.IdUbicacion" class="btn btn-warning btn-sm">Editar</a>

                                    <form asp-action="Eliminar" asp-route-id="@item.IdUbicacion" method="post" class="d-inline form-eliminar" data-confirm data-confirm-title="¿Estás seguro?" data-confirm-text="Esta acción eliminará la ubicación seleccionada." data-confirm-icon="warning" data-confirm-confirm-text="Sí, eliminar" data-confirm-cancel-text="Cancelar">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-danger btn-sm">
                                            Eliminar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                No hay ubicaciones registradas.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
