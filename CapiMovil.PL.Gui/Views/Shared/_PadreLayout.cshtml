@using System.Text.Json
@using Microsoft.AspNetCore.Http
@using CapiMovil.BL.BC
@inject IHttpContextAccessor HttpContextAccessor
@inject PadreFamiliaBC PadreFamiliaBC
@inject NotificacionBC NotificacionBC
@inject IncidenciaBC IncidenciaBC

@{
    var username = HttpContextAccessor.HttpContext?.Session.GetString("Username") ?? "Padre";
    var fotoPerfilUrl = HttpContextAccessor.HttpContext?.Session.GetString("FotoPerfilUrl");
    var inicialUsuario = string.IsNullOrWhiteSpace(username) ? "P" : username.Trim()[0].ToString().ToUpperInvariant();
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    string NavClass(string action)
    {
        return string.Equals(currentController, "PadreFamilia", StringComparison.OrdinalIgnoreCase)
               && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase)
            ? "nav-link active"
            : "nav-link";
    }

    var padreQuickLinks = new[]
    {
        new { Texto = "Dashboard", Url = Url.Action("Index", "PadreFamilia"), Keywords = "inicio panel resumen" },
        new { Texto = "Mis Hijos", Url = Url.Action("MisHijos", "PadreFamilia"), Keywords = "hijos estudiantes" },
        new { Texto = "Seguimiento", Url = Url.Action("Seguimiento", "PadreFamilia"), Keywords = "seguimiento ruta bus" },
        new { Texto = "Mapa en Vivo", Url = Url.Action("MapaEnVivo", "PadreFamilia"), Keywords = "mapa ubicacion tiempo real" },
        new { Texto = "Historial", Url = Url.Action("Historial", "PadreFamilia"), Keywords = "historial eventos" },
        new { Texto = "Notificaciones", Url = Url.Action("Notificaciones", "PadreFamilia"), Keywords = "avisos mensajes alertas" },
        new { Texto = "Perfil", Url = Url.Action("MiPerfil", "Usuario"), Keywords = "perfil cuenta" },
        new { Texto = "Ajustes", Url = Url.Action("CambiarPassword", "Usuario"), Keywords = "ajustes seguridad" },
        new { Texto = "Cambiar contraseña", Url = Url.Action("CambiarPassword", "Usuario"), Keywords = "password clave" }
    };

    var padreNotifications = new List<object>();
    int padreNoLeidas = 0;

    try
    {
        string? usuarioIdSession = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioId");
        if (Guid.TryParse(usuarioIdSession, out Guid idUsuario))
        {
            var padre = PadreFamiliaBC.ObtenerPorIdUsuario(idUsuario);
            if (padre != null)
            {
                var notificaciones = NotificacionBC.ListarPorPadre(padre.IdPadre)
                    .OrderByDescending(x => x.FechaEnvio)
                    .Take(6)
                    .ToList();

                padreNoLeidas = notificaciones.Count(x => !x.Leido);

                padreNotifications.AddRange(notificaciones.Select(n => new
                {
                    Texto = n.Titulo,
                    Url = Url.Action("DetalleNotificacion", "PadreFamilia", new { idNotificacion = n.IdNotificacion }),
                    Tiempo = n.FechaEnvio.ToString("dd/MM HH:mm")
                }));

                var incidencias = IncidenciaBC.ListarPorPadre(padre.IdPadre)
                    .OrderByDescending(x => x.FechaHora)
                    .Take(2);

                foreach (var incidencia in incidencias)
                {
                    padreNotifications.Add(new
                    {
                        Texto = $"Incidencia: {incidencia.TipoIncidencia} ({incidencia.EstadoIncidencia})",
                        Url = Url.Action("Incidencias", "PadreFamilia"),
                        Tiempo = incidencia.FechaHora.ToString("dd/MM HH:mm")
                    });
                }
            }
        }
    }
    catch
    {
        padreNotifications = new List<object>();
        padreNoLeidas = 0;
    }
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CapiMovil</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ui-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/padre-familia.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>
<body class="pf-layout-body">
    <div class="pf-layout-shell" id="pfLayoutShell">
        <aside class="pf-layout-sidebar" id="pfLayoutSidebar">
            <div class="card border-0 shadow-sm h-100 pf-card">
                <div class="card-body d-flex flex-column p-3 p-lg-4">
                    <a asp-controller="PadreFamilia" asp-action="Index" class="d-flex align-items-center gap-2 mb-4 text-decoration-none text-dark">
                        <span class="pf-brand-icon"><i class="bi bi-heart-pulse-fill"></i></span>
                        <div>
                            <div class="fw-bold">CapiMovil</div>
                            <small class="text-muted">Padre de Familia</small>
                        </div>
                    </a>

                    <nav class="nav flex-column gap-2 pf-layout-nav">
                        <a asp-controller="PadreFamilia" asp-action="Index" class="@NavClass("Index")"><i class="bi bi-grid"></i>Dashboard</a>
                        <a asp-controller="PadreFamilia" asp-action="MapaEnVivo" class="@NavClass("MapaEnVivo")"><i class="bi bi-broadcast-pin"></i>Mapa en Vivo</a>
                        <a asp-controller="PadreFamilia" asp-action="Historial" class="@NavClass("Historial")"><i class="bi bi-clock-history"></i>Historial</a>
                        <a asp-controller="PadreFamilia" asp-action="MisHijos" class="@NavClass("MisHijos")"><i class="bi bi-people"></i>Mis Hijos</a>
                        <a asp-controller="PadreFamilia" asp-action="RegistrarHijo" class="@NavClass("RegistrarHijo")"><i class="bi bi-person-plus"></i>Registrar Hijo</a>
                        <a asp-controller="PadreFamilia" asp-action="Seguimiento" class="@NavClass("Seguimiento")"><i class="bi bi-geo-alt"></i>Seguimiento</a>
                        <a asp-controller="PadreFamilia" asp-action="Notificaciones" class="@NavClass("Notificaciones")"><i class="bi bi-bell"></i>Notificaciones</a>
                        <a asp-controller="PadreFamilia" asp-action="MisEventos" class="@NavClass("MisEventos")"><i class="bi bi-clock-history"></i>Actividad</a>
                        <a asp-controller="PadreFamilia" asp-action="Incidencias" class="@NavClass("Incidencias")"><i class="bi bi-exclamation-triangle"></i>Incidencias</a>
                        <a asp-controller="Usuario" asp-action="CambiarPassword" class="nav-link"><i class="bi bi-sliders"></i>Ajustes</a>
                        <a asp-controller="Usuario" asp-action="MiPerfil" class="nav-link"><i class="bi bi-person-circle"></i>Mi Perfil</a>
                    </nav>

                    <a asp-controller="PadreFamilia" asp-action="Seguimiento" class="btn btn-warning mt-auto fw-semibold">
                        <i class="bi bi-broadcast-pin me-2"></i>Rastreo en vivo
                    </a>
                </div>
            </div>
        </aside>
        <div class="pf-layout-backdrop d-xl-none" id="pfLayoutBackdrop"></div>

        <div class="pf-layout-main">
            <header class="card border-0 shadow-sm mb-3 pf-card">
                <div class="card-body p-3 d-flex justify-content-between align-items-center gap-2">
                    <div class="d-flex align-items-center gap-2 flex-grow-1">
                        <button type="button" class="btn btn-light d-xl-none" id="pfSidebarToggle" aria-label="Abrir menú">
                            <i class="bi bi-list"></i>
                        </button>
                        <div class="input-group pf-layout-search app-search position-relative">
                            <span class="input-group-text bg-transparent border-0"><i class="bi bi-search"></i></span>
                            <input id="padreGlobalSearch" class="form-control border-0" placeholder="Buscar sección..." autocomplete="off" />
                            <div id="padreSearchResults" class="admin-search-results list-group shadow-sm d-none" role="listbox" aria-label="Resultados de búsqueda"></div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <div class="position-relative">
                            <button type="button" class="btn btn-light rounded-circle position-relative" id="padreNotificationToggle" aria-label="Notificaciones" aria-expanded="false">
                                <i class="bi bi-bell"></i>
                                @if (padreNoLeidas > 0)
                                {
                                    <span class="badge rounded-pill text-bg-danger position-absolute top-0 start-100 translate-middle">@padreNoLeidas</span>
                                }
                            </button>
                            <div id="padreNotificationPanel" class="app-notification-panel card shadow-sm d-none">
                                <div class="card-body p-2">
                                    <div class="small text-muted px-2 py-1">Notificaciones recientes (Padre)</div>
                                    <div id="padreNotificationList" class="list-group list-group-flush"></div>
                                    <a asp-controller="PadreFamilia" asp-action="Notificaciones" class="btn btn-link btn-sm text-decoration-none w-100">Ver todas</a>
                                </div>
                            </div>
                        </div>
                        <div class="pf-user-pill app-user-pill">
                            @if (!string.IsNullOrWhiteSpace(fotoPerfilUrl))
                            {
                                <img src="@fotoPerfilUrl" alt="Perfil" class="rounded-circle" style="width:24px;height:24px;object-fit:cover;" />
                            }
                            else
                            {
                                <span class="avatar-initial">@inicialUsuario</span>
                            }
                            <span>@username</span>
                        </div>
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-light" type="submit"><i class="bi bi-box-arrow-right"></i></button>
                        </form>
                    </div>
                </div>
            </header>

            <main class="pf-layout-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script id="padre-search-data" type="application/json">
        @Html.Raw(JsonSerializer.Serialize(padreQuickLinks))
    </script>
    <script id="padre-notification-data" type="application/json">
        @Html.Raw(JsonSerializer.Serialize(padreNotifications.Take(8)))
    </script>

    @if (TempData["ok"] != null)
    {
        <script>
            Swal.fire({ icon: 'success', title: 'Éxito', text: @Html.Raw(JsonSerializer.Serialize(TempData["ok"]?.ToString())), confirmButtonText: 'Aceptar' });
        </script>
    }

    @if (TempData["error"] != null)
    {
        <script>
            Swal.fire({ icon: 'error', title: 'Error', text: @Html.Raw(JsonSerializer.Serialize(TempData["error"]?.ToString())), confirmButtonText: 'Aceptar' });
        </script>
    }

    @RenderSection("Scripts", required: false)
    <script>
        (function () {
            const shell = document.getElementById('pfLayoutShell');
            const toggle = document.getElementById('pfSidebarToggle');
            const backdrop = document.getElementById('pfLayoutBackdrop');
            if (!shell || !toggle || !backdrop) return;

            toggle.addEventListener('click', () => shell.classList.toggle('sidebar-open'));
            backdrop.addEventListener('click', () => shell.classList.remove('sidebar-open'));

            shell.querySelectorAll('.pf-layout-nav .nav-link').forEach(link => {
                link.addEventListener('click', () => shell.classList.remove('sidebar-open'));
            });

            window.addEventListener('resize', () => {
                if (window.innerWidth >= 1200) {
                    shell.classList.remove('sidebar-open');
                }
            });
        })();
    </script>
</body>
</html>
