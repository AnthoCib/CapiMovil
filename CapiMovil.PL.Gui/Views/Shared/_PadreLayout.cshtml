@using System.Text.Json
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var username = HttpContextAccessor.HttpContext?.Session.GetString("Username") ?? "Padre";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    string NavClass(string action)
    {
        return string.Equals(currentController, "PadreFamilia", StringComparison.OrdinalIgnoreCase)
               && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase)
            ? "nav-link active"
            : "nav-link";
    }
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CapiMovil</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/padre-familia.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>
<body class="pf-layout-body">
    <div class="pf-layout-shell">
        <aside class="pf-layout-sidebar">
            <div class="card border-0 shadow-sm h-100 pf-card">
                <div class="card-body d-flex flex-column p-3 p-lg-4">
                    <a asp-controller="PadreFamilia" asp-action="Index" class="d-flex align-items-center gap-2 mb-4 text-decoration-none text-dark">
                        <span class="pf-brand-icon"><i class="bi bi-heart-pulse-fill"></i></span>
                        <div>
                            <div class="fw-bold">CapiMovil</div>
                            <small class="text-muted">Padre de Familia</small>
                        </div>
                    </a>

                    <nav class="nav flex-column gap-2 pf-layout-nav">
                        <a asp-controller="PadreFamilia" asp-action="Index" class="@NavClass("Index")"><i class="bi bi-grid"></i>Dashboard</a>
                        <a asp-controller="PadreFamilia" asp-action="MapaEnVivo" class="@NavClass("MapaEnVivo")"><i class="bi bi-broadcast-pin"></i>Mapa en Vivo</a>
                        <a asp-controller="PadreFamilia" asp-action="Historial" class="@NavClass("Historial")"><i class="bi bi-clock-history"></i>Historial</a>
                        <a asp-controller="PadreFamilia" asp-action="MisHijos" class="@NavClass("MisHijos")"><i class="bi bi-people"></i>Mis Hijos</a>
                        <a asp-controller="PadreFamilia" asp-action="Seguimiento" class="@NavClass("Seguimiento")"><i class="bi bi-geo-alt"></i>Seguimiento</a>
                        <a asp-controller="PadreFamilia" asp-action="Notificaciones" class="@NavClass("Notificaciones")"><i class="bi bi-bell"></i>Notificaciones</a>
                        <a asp-controller="PadreFamilia" asp-action="MisEventos" class="@NavClass("MisEventos")"><i class="bi bi-clock-history"></i>Actividad</a>
                        <a asp-controller="PadreFamilia" asp-action="Incidencias" class="@NavClass("Incidencias")"><i class="bi bi-exclamation-triangle"></i>Incidencias</a>
                        <a asp-controller="Usuario" asp-action="CambiarPassword" class="nav-link"><i class="bi bi-sliders"></i>Ajustes</a>
                        <a asp-controller="Usuario" asp-action="MiPerfil" class="nav-link"><i class="bi bi-person-circle"></i>Mi Perfil</a>
                    </nav>

                    <a asp-controller="PadreFamilia" asp-action="Seguimiento" class="btn btn-warning mt-auto fw-semibold">
                        <i class="bi bi-broadcast-pin me-2"></i>Rastreo en vivo
                    </a>
                </div>
            </div>
        </aside>

        <div class="pf-layout-main">
            <header class="card border-0 shadow-sm mb-3 pf-card">
                <div class="card-body p-3 d-flex justify-content-between align-items-center gap-2">
                    <div class="input-group pf-layout-search">
                        <span class="input-group-text bg-transparent border-0"><i class="bi bi-search"></i></span>
                        <input class="form-control border-0" placeholder="Buscar sección..." />
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="btn btn-light rounded-circle"><i class="bi bi-bell"></i></span>
                        <div class="pf-user-pill"><i class="bi bi-person-heart"></i><span>@username</span></div>
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-light" type="submit"><i class="bi bi-box-arrow-right"></i></button>
                        </form>
                    </div>
                </div>
            </header>

            <main class="pf-layout-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (TempData["ok"] != null)
    {
        <script>
            Swal.fire({ icon: 'success', title: 'Éxito', text: @Html.Raw(JsonSerializer.Serialize(TempData["ok"]?.ToString())), confirmButtonText: 'Aceptar' });
        </script>
    }

    @if (TempData["error"] != null)
    {
        <script>
            Swal.fire({ icon: 'error', title: 'Error', text: @Html.Raw(JsonSerializer.Serialize(TempData["error"]?.ToString())), confirmButtonText: 'Aceptar' });
        </script>
    }

    @RenderSection("Scripts", required: false)
</body>
</html>
