@using System.Text.Json
@using Microsoft.AspNetCore.Http
@using CapiMovil.BL.BC
@inject IHttpContextAccessor HttpContextAccessor
@inject ConductorBC ConductorBC
@inject IncidenciaBC IncidenciaBC
@inject RecorridoBC RecorridoBC

@{
    var username = HttpContextAccessor.HttpContext?.Session.GetString("Username") ?? "Conductor";
    var fotoPerfilUrl = HttpContextAccessor.HttpContext?.Session.GetString("FotoPerfilUrl");
    var inicialUsuario = string.IsNullOrWhiteSpace(username) ? "C" : username.Trim()[0].ToString().ToUpperInvariant();
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    string NavClass(string action)
    {
        return string.Equals(currentController, "Conductor", StringComparison.OrdinalIgnoreCase)
               && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase)
            ? "nav-link active"
            : "nav-link";
    }

    var conductorQuickLinks = new[]
    {
        new { Texto = "Dashboard", Url = Url.Action("Index", "Conductor"), Keywords = "inicio panel resumen" },
        new { Texto = "Mi Ruta", Url = Url.Action("MiRuta", "Conductor"), Keywords = "ruta mapa paraderos trayecto" },
        new { Texto = "Recorridos", Url = Url.Action("Recorrido", "Conductor"), Keywords = "operacion iniciar finalizar" },
        new { Texto = "Estudiantes", Url = Url.Action("Estudiantes", "Conductor"), Keywords = "alumnos lista" },
        new { Texto = "Abordaje", Url = Url.Action("Abordaje", "Conductor"), Keywords = "subida bajada eventos" },
        new { Texto = "Incidencias", Url = Url.Action("Incidencias", "Conductor"), Keywords = "alertas reportes" },
        new { Texto = "Mi Bus", Url = Url.Action("MiBus", "Conductor"), Keywords = "bus unidad placa" },
        new { Texto = "Seguimiento en vivo", Url = Url.Action("MiRuta", "Conductor"), Keywords = "seguimiento vivo mapa" },
        new { Texto = "Perfil", Url = Url.Action("MiPerfil", "Usuario"), Keywords = "perfil cuenta usuario" },
        new { Texto = "Cambiar contraseña", Url = Url.Action("CambiarPassword", "Usuario"), Keywords = "password clave seguridad" }
    };

    var conductorNotifications = new List<object>();
    int conductorNoLeidas = 0;

    try
    {
        string? usuarioIdSession = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioId");
        if (Guid.TryParse(usuarioIdSession, out Guid idUsuario))
        {
            var conductor = ConductorBC.ObtenerPorIdUsuario(idUsuario);
            if (conductor != null)
            {
                var incidencias = IncidenciaBC.ListarPorConductor(conductor.IdConductor)
                    .OrderByDescending(x => x.FechaHora)
                    .Take(5)
                    .ToList();

                conductorNoLeidas = incidencias.Count(x => !string.Equals(x.EstadoIncidencia, "CERRADA", StringComparison.OrdinalIgnoreCase));

                conductorNotifications.AddRange(incidencias.Select(x => new
                {
                    Texto = $"[{x.EstadoIncidencia}] {x.TipoIncidencia}",
                    Url = Url.Action("Incidencias", "Conductor"),
                    Tiempo = x.FechaHora.ToString("dd/MM HH:mm")
                }));

                var recorridosActivos = RecorridoBC.ListarPorConductor(conductor.IdConductor)
                    .Where(x => x.EstadoRecorrido == "PROGRAMADO" || x.EstadoRecorrido == "EN_CURSO")
                    .OrderByDescending(x => x.Fecha)
                    .Take(3);

                foreach (var recorrido in recorridosActivos)
                {
                    conductorNotifications.Add(new
                    {
                        Texto = $"Recorrido {recorrido.CodigoRecorrido}: {recorrido.EstadoRecorrido}",
                        Url = Url.Action("Recorrido", "Conductor"),
                        Tiempo = recorrido.Fecha.ToString("dd/MM/yyyy")
                    });
                }
            }
        }
    }
    catch
    {
        conductorNotifications = new List<object>();
        conductorNoLeidas = 0;
    }
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CapiMovil</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ui-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/conductor-dashboard.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>
<body class="conductor-layout-body">
    <div class="conductor-layout-shell" id="conductorLayoutShell" data-sidebar-shell data-sidebar-nav=".conductor-layout-nav .nav-link" data-sidebar-breakpoint="1200">
        <aside class="conductor-layout-sidebar" id="conductorLayoutSidebar">
            <div class="card border-0 shadow-sm h-100 conductor-soft-card">
                <div class="card-body d-flex flex-column p-3 p-lg-4">
                    <a asp-controller="Conductor" asp-action="Index" class="d-flex align-items-center gap-2 mb-4 text-decoration-none text-dark">
                        <span class="conductor-brand-icon"><i class="bi bi-bus-front-fill"></i></span>
                        <div>
                            <div class="fw-bold">CapiMovil</div>
                            <small class="text-muted">Panel Conductor</small>
                        </div>
                    </a>

                    <nav class="nav flex-column gap-2 conductor-layout-nav">
                        <a asp-controller="Conductor" asp-action="Index" class="@NavClass("Index")"><i class="bi bi-grid"></i>Dashboard</a>
                        <a asp-controller="Conductor" asp-action="MiRuta" class="@NavClass("MiRuta")"><i class="bi bi-map"></i>Mi Ruta</a>
                        <a asp-controller="Conductor" asp-action="Recorrido" class="@NavClass("Recorrido")"><i class="bi bi-signpost"></i>Recorridos</a>
                        <a asp-controller="Conductor" asp-action="Estudiantes" class="@NavClass("Estudiantes")"><i class="bi bi-people"></i>Estudiantes</a>
                        <a asp-controller="Conductor" asp-action="Abordaje" class="@NavClass("Abordaje")"><i class="bi bi-check2-square"></i>Abordaje</a>
                        <a asp-controller="Conductor" asp-action="Incidencias" class="@NavClass("Incidencias")"><i class="bi bi-exclamation-triangle"></i>Incidencias</a>
                        <a asp-controller="Conductor" asp-action="MiBus" class="@NavClass("MiBus")"><i class="bi bi-bus-front"></i>Mi Bus</a>
                        <a asp-controller="Usuario" asp-action="CambiarPassword" class="nav-link"><i class="bi bi-key"></i>Ajustes</a>
                        <a asp-controller="Usuario" asp-action="MiPerfil" class="nav-link"><i class="bi bi-person-circle"></i>Mi Perfil</a>
                    </nav>

                    <a asp-controller="Conductor" asp-action="MiRuta" class="btn btn-conductor-live mt-auto">
                        <i class="bi bi-broadcast-pin me-2"></i>Seguimiento en vivo
                    </a>
                </div>
            </div>
        </aside>
        <div class="conductor-layout-backdrop d-xl-none" id="conductorLayoutBackdrop" data-sidebar-backdrop></div>

        <div class="conductor-layout-main">
            <header class="card border-0 shadow-sm mb-3 conductor-soft-card">
                <div class="card-body p-3 d-flex justify-content-between align-items-center gap-3">
                    <div class="d-flex align-items-center gap-2 flex-grow-1">
                        <button type="button" class="btn btn-light d-xl-none" id="conductorSidebarToggle" data-sidebar-toggle aria-label="Abrir menú">
                            <i class="bi bi-list"></i>
                        </button>
                        <div class="conductor-layout-search app-search-wrap position-relative">
                            <div class="input-group app-search">
                                <span class="input-group-text bg-transparent border-0"><i class="bi bi-search"></i></span>
                                <input id="conductorGlobalSearch" class="form-control border-0" placeholder="Buscar acción..." autocomplete="off" />
                            </div>
                            <div id="conductorSearchResults" class="admin-search-results list-group shadow-sm d-none" role="listbox" aria-label="Resultados de búsqueda"></div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <div class="position-relative">
                            <button type="button" class="btn btn-light rounded-circle position-relative" id="conductorNotificationToggle" aria-label="Notificaciones" aria-expanded="false">
                                <i class="bi bi-bell"></i>
                                @if (conductorNoLeidas > 0)
                                {
                                    <span class="badge rounded-pill text-bg-danger position-absolute top-0 start-100 translate-middle">@conductorNoLeidas</span>
                                }
                            </button>
                            <div id="conductorNotificationPanel" class="app-notification-panel card shadow-sm d-none">
                                <div class="card-body p-2">
                                    <div class="small text-muted px-2 py-1">Notificaciones recientes (Conductor)</div>
                                    <div id="conductorNotificationList" class="list-group list-group-flush"></div>
                                    <a asp-controller="Conductor" asp-action="Incidencias" class="btn btn-link btn-sm text-decoration-none w-100">Ver todas</a>
                                </div>
                            </div>
                        </div>
                        <div class="conductor-user-pill app-user-pill">
                            @if (!string.IsNullOrWhiteSpace(fotoPerfilUrl))
                            {
                                <img src="@fotoPerfilUrl" alt="Perfil" class="rounded-circle" style="width:24px;height:24px;object-fit:cover;" />
                            }
                            else
                            {
                                <span class="avatar-initial">@inicialUsuario</span>
                            }
                            <span>@username</span>
                        </div>
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-light" type="submit" aria-label="Cerrar sesión"><i class="bi bi-box-arrow-right"></i></button>
                        </form>
                    </div>
                </div>
            </header>

            <main class="conductor-layout-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/capimovil-maps.js" asp-append-version="true"></script>
    <script id="conductor-search-data" type="application/json">
        @Html.Raw(JsonSerializer.Serialize(conductorQuickLinks))
    </script>
    <script id="conductor-notification-data" type="application/json">
        @Html.Raw(JsonSerializer.Serialize(conductorNotifications.Take(8)))
    </script>
    <partial name="_SweetAlertMessages" />

    @RenderSection("Scripts", required: false)
</body>
</html>
