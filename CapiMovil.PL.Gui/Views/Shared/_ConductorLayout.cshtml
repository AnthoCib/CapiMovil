@using System.Text.Json
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var username = HttpContextAccessor.HttpContext?.Session.GetString("Username") ?? "Conductor";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    string NavClass(string action)
    {
        return string.Equals(currentController, "Conductor", StringComparison.OrdinalIgnoreCase)
               && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase)
            ? "nav-link active"
            : "nav-link";
    }
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CapiMovil</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/conductor-dashboard.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>
<body class="conductor-layout-body">
    <div class="conductor-layout-shell">
        <aside class="conductor-layout-sidebar">
            <div class="card border-0 shadow-sm h-100 conductor-soft-card">
                <div class="card-body d-flex flex-column p-3 p-lg-4">
                    <a asp-controller="Conductor" asp-action="Index" class="d-flex align-items-center gap-2 mb-4 text-decoration-none text-dark">
                        <span class="conductor-brand-icon"><i class="bi bi-bus-front-fill"></i></span>
                        <div>
                            <div class="fw-bold">CapiMovil</div>
                            <small class="text-muted">Panel Conductor</small>
                        </div>
                    </a>

                    <nav class="nav flex-column gap-2 conductor-layout-nav">
                        <a asp-controller="Conductor" asp-action="Index" class="@NavClass("Index")"><i class="bi bi-grid"></i>Dashboard</a>
                        <a asp-controller="Conductor" asp-action="MiRuta" class="@NavClass("MiRuta")"><i class="bi bi-map"></i>Mi Ruta</a>
                        <a asp-controller="Conductor" asp-action="Recorrido" class="@NavClass("Recorrido")"><i class="bi bi-signpost"></i>Recorridos</a>
                        <a asp-controller="Conductor" asp-action="Estudiantes" class="@NavClass("Estudiantes")"><i class="bi bi-people"></i>Estudiantes</a>
                        <a asp-controller="Conductor" asp-action="Abordaje" class="@NavClass("Abordaje")"><i class="bi bi-check2-square"></i>Abordaje</a>
                        <a asp-controller="Conductor" asp-action="Incidencias" class="@NavClass("Incidencias")"><i class="bi bi-exclamation-triangle"></i>Incidencias</a>
                        <a asp-controller="Conductor" asp-action="MiBus" class="@NavClass("MiBus")"><i class="bi bi-bus-front"></i>Mi Bus</a>
                    </nav>

                    <a asp-controller="Conductor" asp-action="MiRuta" class="btn btn-conductor-live mt-auto">
                        <i class="bi bi-broadcast-pin me-2"></i>Seguimiento en vivo
                    </a>
                </div>
            </div>
        </aside>

        <div class="conductor-layout-main">
            <header class="card border-0 shadow-sm mb-3 conductor-soft-card">
                <div class="card-body p-3 d-flex justify-content-between align-items-center gap-3">
                    <div class="input-group conductor-layout-search">
                        <span class="input-group-text bg-transparent border-0"><i class="bi bi-search"></i></span>
                        <input class="form-control border-0" placeholder="Buscar acción..." />
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <button type="button" class="btn btn-light rounded-circle" aria-label="Notificaciones">
                            <i class="bi bi-bell"></i>
                        </button>
                        <div class="conductor-user-pill"><i class="bi bi-person-circle"></i><span>@username</span></div>
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-light" type="submit" aria-label="Cerrar sesión"><i class="bi bi-box-arrow-right"></i></button>
                        </form>
                    </div>
                </div>
            </header>

            <main class="conductor-layout-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/capimovil-maps.js" asp-append-version="true"></script>

    @if (TempData["ok"] != null)
    {
        <script>
            Swal.fire({ icon: 'success', title: 'Éxito', text: @Html.Raw(JsonSerializer.Serialize(TempData["ok"]?.ToString())), confirmButtonText: 'Aceptar' });
        </script>
    }

    @if (TempData["error"] != null)
    {
        <script>
            Swal.fire({ icon: 'error', title: 'Error', text: @Html.Raw(JsonSerializer.Serialize(TempData["error"]?.ToString())), confirmButtonText: 'Aceptar' });
        </script>
    }

    @if (ViewBag.SwalError != null)
    {
        <script>
            Swal.fire({ icon: 'error', title: 'Error', text: @Html.Raw(JsonSerializer.Serialize(ViewBag.SwalError?.ToString())), confirmButtonText: 'Aceptar' });
        </script>
    }

    @RenderSection("Scripts", required: false)
</body>
</html>
