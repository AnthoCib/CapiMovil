@using System.Text.Json
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var httpContext = HttpContextAccessor.HttpContext;
    var username = httpContext?.Session.GetString("Username");
    var rol = httpContext?.Session.GetString("RolNombre");
    var rolNormalizado = (rol ?? "").Trim().ToUpperInvariant();
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CapiMovil</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
 
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

    @if (!string.IsNullOrEmpty(username))
    {
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-bus-front-fill me-2"></i>CapiMovil
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal"
                        aria-controls="menuPrincipal" aria-expanded="false" aria-label="Mostrar navegación">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menuPrincipal">
                 
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        @if (rolNormalizado == "ADMINISTRADOR" || rolNormalizado == "ADMIN")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-house-door me-1"></i>Inicio
                                </a>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-shield-lock me-1"></i>Seguridad
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Rol" asp-action="Listar">Roles</a></li>
                                    <li><a class="dropdown-item" asp-controller="Usuario" asp-action="Listar">Usuarios</a></li>
                                </ul>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-people me-1"></i>Personas
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="PadreFamilia" asp-action="Listar">Padres de Familia</a></li>
                                    <li><a class="dropdown-item" asp-controller="Conductor" asp-action="Listar">Conductores</a></li>
                                    <li><a class="dropdown-item" asp-controller="Estudiante" asp-action="Listar">Estudiantes</a></li>
                                </ul>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-bus-front me-1"></i>Transporte
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Bus" asp-action="Listar">Buses</a></li>
                                    <li><a class="dropdown-item" asp-controller="Ruta" asp-action="Listar">Rutas</a></li>
                                    <li><a class="dropdown-item" asp-controller="Paradero" asp-action="Listar">Paraderos</a></li>
                                    <li><a class="dropdown-item" asp-controller="RutaEstudiante" asp-action="Listar">Ruta - Estudiante</a></li>
                                </ul>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-gear me-1"></i>Operaciones
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Recorrido" asp-action="Listar">Recorridos</a></li>
                                    <li><a class="dropdown-item" asp-controller="EventoAbordaje" asp-action="Listar">Eventos de Abordaje</a></li>
                                    <li><a class="dropdown-item" asp-controller="UbicacionBus" asp-action="Listar">Ubicación de Bus</a></li>
                                    <li><a class="dropdown-item" asp-controller="Incidencia" asp-action="Listar">Incidencias</a></li>
                                    <li><a class="dropdown-item" asp-controller="Notificacion" asp-action="Listar">Notificaciones</a></li>
                                </ul>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auditoria" asp-action="Listar">
                                    <i class="bi bi-clipboard-data me-1"></i>Auditoría
                                </a>
                            </li>
                        }
                        else if (rolNormalizado == "CONDUCTOR")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Conductor" asp-action="Index">
                                    <i class="bi bi-house-door me-1"></i>Inicio
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Conductor" asp-action="MiBus">
                                    <i class="bi bi-bus-front me-1"></i>Mi Bus
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Conductor" asp-action="MiRuta">
                                    <i class="bi bi-signpost-2 me-1"></i>Mi Ruta
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Conductor" asp-action="Estudiantes">
                                    <i class="bi bi-people me-1"></i>Estudiantes
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Conductor" asp-action="Recorrido">
                                    <i class="bi bi-geo-alt me-1"></i>Recorrido
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Conductor" asp-action="Abordaje">
                                    <i class="bi bi-check2-square me-1"></i>Abordaje
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Conductor" asp-action="Incidencias">
                                    <i class="bi bi-exclamation-triangle me-1"></i>Incidencias
                                </a>
                            </li>
                        }
                        else if (rolNormalizado == "PADRE" || rolNormalizado == "PADRE DE FAMILIA")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="PadreFamilia" asp-action="Index">
                                    <i class="bi bi-house-door me-1"></i>Inicio
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="PadreFamilia" asp-action="MisHijos">
                                    <i class="bi bi-people me-1"></i>Mis Hijos
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="PadreFamilia" asp-action="MiRuta">
                                    <i class="bi bi-signpost-2 me-1"></i>Ruta
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="PadreFamilia" asp-action="MiParadero">
                                    <i class="bi bi-geo me-1"></i>Paradero
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="PadreFamilia" asp-action="Seguimiento">
                                    <i class="bi bi-activity me-1"></i>Seguimiento
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="PadreFamilia" asp-action="Incidencias">
                                    <i class="bi bi-exclamation-diamond me-1"></i>Incidencias
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="PadreFamilia" asp-action="MisEventos">
                                    <i class="bi bi-clock-history me-1"></i>Abordajes
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="PadreFamilia" asp-action="Notificaciones">
                                    <i class="bi bi-bell me-1"></i>Notificaciones
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i>
                                <span>@username</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                <li>
                                    <span class="dropdown-item-text">
                                        <strong>Rol:</strong> @rol
                                    </span>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Usuario" asp-action="MiPerfil">
                                        <i class="bi bi-person me-2"></i>Mi perfil
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Usuario" asp-action="CambiarPassword">
                                        <i class="bi bi-key me-2"></i>Cambiar contraseña
                                    </a>

                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-box-arrow-right me-2"></i>Cerrar sesión
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </ul>

                </div>
            </div>
        </nav>
    }

    <main class="container py-4 flex-fill">
        @RenderBody()
    </main>

    <footer class="border-top py-3 mt-auto bg-light">
        <div class="container text-center text-muted">
            &copy; @DateTime.Now.Year - CapiMovil
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (TempData["ok"] != null)
    {
        <script>
            Swal.fire({
            icon: 'success',
            title: 'Éxito',
            text: @Html.Raw(JsonSerializer.Serialize(TempData["ok"]?.ToString())),
            confirmButtonText: 'Aceptar'
            });
        </script>
    }

    @if (TempData["error"] != null)
    {
        <script>
            Swal.fire({
            icon: 'error',
            title: 'Error',
            text: @Html.Raw(JsonSerializer.Serialize(TempData["error"]?.ToString())),
            confirmButtonText: 'Aceptar'
            });
        </script>
    }

    @if (ViewBag.SwalError != null)
    {
        <script>
            Swal.fire({
            icon: 'error',
            title: 'Error',
            text: @Html.Raw(JsonSerializer.Serialize(ViewBag.SwalError?.ToString())),
            confirmButtonText: 'Aceptar'
            });
        </script>
    }

    @RenderSection("Scripts", required: false)
</body>
</html>