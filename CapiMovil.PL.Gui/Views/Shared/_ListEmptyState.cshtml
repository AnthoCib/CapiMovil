@model (string titulo, string mensaje, string icono)

<div class="list-empty-state text-center">
    <div class="list-empty-icon mb-2">
        <i class="bi @(string.IsNullOrWhiteSpace(Model.icono) ? "bi-inbox" : Model.icono)"></i>
    </div>
    <h6 class="mb-1">@Model.titulo</h6>
    <p class="text-muted mb-0">@Model.mensaje</p>
</div>
