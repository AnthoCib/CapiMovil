@model CapiMovil.PL.Gui.Models.ViewModels.ConductorMiRutaViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Mi Ruta";

    var paraderosMapa = Model.Paraderos
        .Where(p => p.Latitud.HasValue && p.Longitud.HasValue)
        .Select(p => new
        {
            nombre = p.Nombre,
            direccion = p.Direccion,
            ordenParada = p.OrdenParada,
            latitud = p.Latitud,
            longitud = p.Longitud
        })
        .ToList();

    var busMapa = Model.UltimaUbicacionBus == null
        ? null
        : new
        {
            latitud = Model.UltimaUbicacionBus.Latitud,
            longitud = Model.UltimaUbicacionBus.Longitud,
            fechaHora = Model.UltimaUbicacionBus.FechaHora.ToString("dd/MM/yyyy HH:mm")
        };
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
          crossorigin="" />
}

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <h2 class="fw-bold mb-2"><i class="bi bi-signpost-split-fill text-primary me-2"></i>Mi Ruta Operativa</h2>
        @if (Model.RecorridoOperacion == null)
        {
            <div class="alert alert-warning mb-0">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>No tienes recorrido activo ni programado para hoy.
            </div>
        }
        else
        {
            <div class="row g-2">
                <div class="col-md-3"><span class="badge text-bg-primary">@Model.RecorridoOperacion.CodigoRecorrido</span></div>
                <div class="col-md-4"><strong>Ruta:</strong> @Model.RecorridoOperacion.Ruta?.CodigoRuta - @Model.RecorridoOperacion.Ruta?.Nombre</div>
                <div class="col-md-3"><strong>Estado:</strong> <span class="badge text-bg-info">@Model.RecorridoOperacion.EstadoRecorrido</span></div>
                <div class="col-md-2"><strong>Fecha:</strong> @Model.RecorridoOperacion.Fecha.ToString("dd/MM/yyyy")</div>
            </div>
        }
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <h5 class="fw-bold mb-1"><i class="bi bi-map-fill text-success me-2"></i>Mapa operativo</h5>
                <p class="text-muted mb-0">Paraderos de la ruta y última ubicación registrada del bus.</p>
            </div>
            <div class="card-body">
                @if (!paraderosMapa.Any() && busMapa == null)
                {
                    <div class="alert alert-secondary mb-0">
                        <i class="bi bi-info-circle me-2"></i>No hay coordenadas de paraderos ni ubicación de bus disponibles para mostrar.
                    </div>
                }
                else
                {
                    <div id="mapConductorRuta" class="capi-map"></div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="bi bi-geo-alt me-2"></i>Resumen geográfico</h6>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between px-0">
                        <span>Paraderos con coordenadas</span>
                        <span class="badge text-bg-primary">@paraderosMapa.Count</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between px-0">
                        <span>Última ubicación bus</span>
                        <span class="badge @(busMapa == null ? "text-bg-secondary" : "text-bg-success")">@(busMapa == null ? "Sin data" : "Disponible")</span>
                    </li>
                </ul>
            </div>
        </div>

        @if (Model.Paraderos.Any())
        {
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-signpost me-2"></i>Paraderos de la ruta</h6>
                    <ol class="small mb-0">
                        @foreach (var p in Model.Paraderos)
                        {
                            <li class="mb-2">
                                <strong>@p.Nombre</strong><br />
                                <span class="text-muted">@p.Direccion</span>
                            </li>
                        }
                    </ol>
                </div>
            </div>
        }
    </div>
</div>

<div class="card shadow-sm border-0 mt-3">
    <div class="card-body">
        <h5 class="fw-bold mb-3"><i class="bi bi-clock-history me-2"></i>Historial de recorridos asignados</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-primary">
                    <tr><th>Recorrido</th><th>Ruta</th><th>Bus</th><th>Fecha</th><th>Estado</th></tr>
                </thead>
                <tbody>
                    @if (Model.Recorridos.Any())
                    {
                        foreach (var item in Model.Recorridos)
                        {
                            <tr>
                                <td>@item.CodigoRecorrido</td>
                                <td>@item.Ruta?.CodigoRuta - @item.Ruta?.Nombre</td>
                                <td>@item.Bus?.CodigoBus - @item.Bus?.Placa</td>
                                <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                <td><span class="badge text-bg-light border">@item.EstadoRecorrido</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center text-muted">No tienes rutas/recorridos asignados.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>

    @if (paraderosMapa.Any() || busMapa != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                CapiMovilMaps.createRouteViewer({
                    mapId: 'mapConductorRuta',
                    paraderos: @Html.Raw(JsonSerializer.Serialize(paraderosMapa)),
                    busLocation: @Html.Raw(JsonSerializer.Serialize(busMapa)),
                    defaultCenter: [-12.046374, -77.042793]
                });
            });
        </script>
    }
}
