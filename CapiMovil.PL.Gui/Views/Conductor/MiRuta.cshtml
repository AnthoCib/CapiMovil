@model CapiMovil.PL.Gui.Models.ViewModels.ConductorMiRutaViewModel
@{
    ViewData["Title"] = "Mi Ruta";
}

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <h2 class="fw-bold mb-3">Mi Ruta</h2>
        @if (Model.RecorridoOperacion == null)
        {
            <div class="alert alert-warning mb-0">No tienes recorrido activo ni programado para hoy.</div>
        }
        else
        {
            <div class="row g-2">
                <div class="col-md-4"><strong>Recorrido:</strong> @Model.RecorridoOperacion.CodigoRecorrido</div>
                <div class="col-md-4"><strong>Ruta:</strong> @Model.RecorridoOperacion.Ruta?.CodigoRuta - @Model.RecorridoOperacion.Ruta?.Nombre</div>
                <div class="col-md-4"><strong>Estado:</strong> @Model.RecorridoOperacion.EstadoRecorrido</div>
            </div>
        }
    </div>
</div>

@if (Model.Paraderos.Any())
{
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            <h5 class="fw-bold mb-3">Paraderos de la ruta</h5>
            <ol class="mb-0">
                @foreach (var p in Model.Paraderos)
                {
                    <li><strong>@p.Nombre</strong> - @p.Direccion</li>
                }
            </ol>
        </div>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <h5 class="fw-bold mb-3">Historial de recorridos asignados</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-primary">
                    <tr><th>Recorrido</th><th>Ruta</th><th>Bus</th><th>Fecha</th><th>Estado</th></tr>
                </thead>
                <tbody>
                    @if (Model.Recorridos.Any())
                    {
                        foreach (var item in Model.Recorridos)
                        {
                            <tr>
                                <td>@item.CodigoRecorrido</td>
                                <td>@item.Ruta?.CodigoRuta - @item.Ruta?.Nombre</td>
                                <td>@item.Bus?.CodigoBus - @item.Bus?.Placa</td>
                                <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@item.EstadoRecorrido</td>
                            </tr>
                        }
                    }
                    else { <tr><td colspan="5" class="text-center text-muted">No tienes rutas/recorridos asignados.</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>
