@model CapiMovil.BL.BE.ConductorBE
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Conductor Asignado";
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <h2 class="fw-bold mb-3">Conductor Asignado</h2>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label text-muted">Código</label>
                <div class="fw-semibold">@Model.CodigoConductor</div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted">Nombre</label>
                <div class="fw-semibold">@Model.NombreCompleto</div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted">DNI</label>
                <div class="fw-semibold">@Model.DNI</div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted">Licencia</label>
                <div class="fw-semibold">@Model.Licencia (@Model.CategoriaLicencia)</div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted">Teléfono</label>
                <div class="fw-semibold">@Model.Telefono</div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted">Estado</label>
                <div class="fw-semibold">@(Model.Estado ? "Activo" : "Inactivo")</div>
            </div>
        </div>
    </div>
</div>
