@model CapiMovil.PL.Gui.Models.ViewModels.ConductorDashboardViewModel

@{
    ViewData["Title"] = "Recorrido";
}

@functions {
    string HoraTexto(TimeSpan? hora)
    {
        if (hora.HasValue)
        {
            return DateTime.Today.Add(hora.Value).ToString("hh:mm tt");
        }

        return "Sin hora";
    }

    string EstadoTexto(string? estado)
    {
        string valor = (estado ?? "").Trim().ToUpperInvariant();

        if (valor == "PROGRAMADO") return "Programado";
        if (valor == "EN_CURSO") return "En curso";
        if (valor == "FINALIZADO") return "Finalizado";
        if (valor == "CANCELADO") return "Cancelado";

        return string.IsNullOrWhiteSpace(estado) ? "Programado" : estado;
    }

    string EstadoBadge(string? estado)
    {
        string valor = (estado ?? "").Trim().ToUpperInvariant();

        if (valor == "PROGRAMADO") return "bg-warning text-dark";
        if (valor == "EN_CURSO") return "bg-primary";
        if (valor == "FINALIZADO") return "bg-success";
        if (valor == "CANCELADO") return "bg-danger";

        return "bg-secondary";
    }
}

<div class="dashboard-conductor">

    <div class="dashboard-saludo mb-4">
        <h1>Recorrido</h1>
        <p>Consulta el estado general del recorrido actual.</p>
    </div>

    @if (Model.RecorridoActual == null)
    {
        <div class="card-conductor p-4 text-center">
            <i class="bi bi-map fs-1 text-warning"></i>

            <h2 class="titulo-card mt-3">Sin recorrido activo</h2>

            <p class="text-muted mb-0">
                No tienes un recorrido asignado para mostrar en esta sección.
            </p>
        </div>
    }
    else
    {
        <div class="card-conductor p-4 mb-4">

            <div class="d-flex justify-content-between align-items-start mb-4">
                <div>
                    <h2 class="titulo-card mb-1">
                        @(Model.RecorridoActual.Ruta?.Nombre ?? "Ruta asignada")
                    </h2>

                    <p class="text-muted mb-0">
                        Código recorrido: @Model.RecorridoActual.CodigoRecorrido
                    </p>
                </div>

                <span class="badge @EstadoBadge(Model.RecorridoActual.EstadoRecorrido)">
                    @EstadoTexto(Model.RecorridoActual.EstadoRecorrido)
                </span>
            </div>

            <div class="row g-3">

                <div class="col-md-3">
                    <small class="text-muted">Bus asignado</small>
                    <strong class="d-block">
                        @(Model.RecorridoActual.Bus?.CodigoBus ?? "Sin bus")
                    </strong>
                </div>

                <div class="col-md-3">
                    <small class="text-muted">Placa</small>
                    <strong class="d-block">
                        @(Model.RecorridoActual.Bus?.Placa ?? "-")
                    </strong>
                </div>

                <div class="col-md-3">
                    <small class="text-muted">Hora inicio</small>
                    <strong class="d-block">
                        @HoraTexto(Model.RecorridoActual.HoraInicioProgramada)
                    </strong>
                </div>

                <div class="col-md-3">
                    <small class="text-muted">Hora fin</small>
                    <strong class="d-block">
                        @HoraTexto(Model.RecorridoActual.HoraFinProgramada)
                    </strong>
                </div>

            </div>

        </div>

        <div class="card-conductor p-4 text-center mb-4">
            <i class="bi bi-map fs-1 text-warning"></i>

            <h2 class="titulo-card mt-3">Mapa del recorrido</h2>

            <p class="text-muted mb-0">
                Esta sección queda reservada para integrar el mapa o seguimiento del bus.
            </p>
        </div>

        <div class="card-conductor p-4">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h2 class="titulo-card mb-1">Resumen de avance</h2>
                    <p class="text-muted mb-0">
                        Revisión general de paraderos y estudiantes registrados.
                    </p>
                </div>
            </div>

            <div class="row g-3">

                <div class="col-md-4">
                    <div class="ruta-etapa-card h-100">
                        <small>Paraderos de recojo</small>
                        <h4 class="mb-1">@Model.ParaderosRecojo.Count</h4>
                        <p class="text-muted mb-0">
                            Completados:
                            @Model.ParaderosRecojo.Count(p => p.Completado)
                            /
                            @Model.ParaderosRecojo.Count
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="ruta-etapa-card h-100">
                        <small>Paraderos de entrega</small>
                        <h4 class="mb-1">@Model.ParaderosEntrega.Count</h4>
                        <p class="text-muted mb-0">
                            Completados:
                            @Model.ParaderosEntrega.Count(p => p.Completado)
                            /
                            @Model.ParaderosEntrega.Count
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="ruta-etapa-card h-100">
                        <small>Estudiantes en ruta</small>
                        <h4 class="mb-1">@Model.TotalEstudiantes</h4>
                        <p class="text-muted mb-0">
                            Según el recorrido actual.
                        </p>
                    </div>
                </div>

            </div>

        </div>
    }

</div>