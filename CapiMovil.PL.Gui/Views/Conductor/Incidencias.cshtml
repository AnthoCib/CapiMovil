@model CapiMovil.PL.Gui.Models.ViewModels.ConductorDashboardViewModel

@{
    ViewData["Title"] = "Incidencias";
}

<div class="dashboard-conductor">
    <div class="dashboard-saludo mb-4 d-flex justify-content-between align-items-start">
        <div>
            <h1>Incidencias</h1>
            <p>Consulta y reporta incidencias del recorrido actual.</p>
        </div>

        @if (Model.RecorridoActual != null)
        {
            <button type="button"
                    class="btn btn-danger"
                    data-bs-toggle="modal"
                    data-bs-target="#modalRegistrarIncidencia">
                Reportar incidencia
            </button>
        }
    </div>

    <div class="card-conductor p-4">
        <h2 class="titulo-card mb-3">Incidencias reportadas</h2>

        @if (Model.IncidenciasPendientes == null || !Model.IncidenciasPendientes.Any())
        {
            <p class="text-muted mb-0">No hay incidencias reportadas para este recorrido.</p>
        }
        else
        {
            foreach (var incidencia in Model.IncidenciasPendientes)
            {
                <div class="ruta-etapa-card mb-3">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h5>@incidencia.TipoIncidencia</h5>
                            <p class="mb-1">@incidencia.Descripcion</p>
                            <small>@incidencia.FechaHora.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>

                        <span class="badge bg-warning text-dark">@incidencia.Prioridad</span>
                    </div>
                </div>
            }
        }
    </div>
</div>

@if (Model.RecorridoActual != null)
{
    <div class="modal fade" id="modalRegistrarIncidencia" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-controller="Conductor"
                      asp-action="RegistrarIncidenciaConductor"
                      method="post"
                      onsubmit="return confirm('¿Deseas registrar esta incidencia?');">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="idRecorrido" value="@Model.RecorridoActual.IdRecorrido" />

                    <div class="modal-header">
                        <h5 class="modal-title">Reportar incidencia</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Tipo</label>
                            <select name="tipoIncidencia" class="form-select" required>
                                <option value="">Seleccione...</option>
                                <option value="RETRASO">Retraso</option>
                                <option value="DESVIO">Desvío</option>
                                <option value="TRAFICO">Tráfico</option>
                                <option value="FALLA MECANICA">Falla mecánica</option>
                                <option value="ACCIDENTE">Accidente</option>
                                <option value="OTRO">Otro</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Prioridad</label>
                            <select name="prioridad" class="form-select" required>
                                <option value="BAJA">Baja</option>
                                <option value="MEDIA" selected>Media</option>
                                <option value="ALTA">Alta</option>
                                <option value="CRITICA">Crítica</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Descripción</label>
                            <textarea name="descripcion" class="form-control" rows="3" maxlength="300" required></textarea>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            Cancelar
                        </button>

                        <button type="submit" class="btn btn-danger">
                            Reportar incidencia
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}