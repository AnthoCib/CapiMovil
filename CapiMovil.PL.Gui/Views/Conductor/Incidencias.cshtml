@model CapiMovil.PL.Gui.Models.ViewModels.ConductorIncidenciasViewModel
@{
    ViewData["Title"] = "Incidencias";
}

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <h2 class="fw-bold mb-3">Registrar incidencia</h2>
        @if (Model.RecorridoOperacion == null)
        {
            <div class="alert alert-warning mb-0">No tienes recorridos asignados para registrar incidencias.</div>
        }
        else
        {
            <p><strong>Recorrido:</strong> @Model.RecorridoOperacion.CodigoRecorrido - @Model.RecorridoOperacion.Fecha.ToString("dd/MM/yyyy")</p>
            <form asp-action="RegistrarIncidencia" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <div class="col-md-3">
                    <label class="form-label">Tipo</label>
                    <select asp-for="TipoIncidencia" asp-items="Model.TiposIncidencia" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Prioridad</label>
                    <select asp-for="Prioridad" asp-items="Model.Prioridades" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Fecha/Hora</label>
                    <input asp-for="FechaHora" class="form-control" type="datetime-local" value="@Model.FechaHora.ToString("yyyy-MM-ddTHH:mm")" />
                </div>
                <div class="col-12">
                    <label class="form-label">Descripción</label>
                    <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">Registrar incidencia</button>
                </div>
            </form>
        }
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <h5 class="fw-bold mb-3">Mis Incidencias</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-primary"><tr><th>Código</th><th>Tipo</th><th>Fecha/Hora</th><th>Prioridad</th><th>Estado</th></tr></thead>
                <tbody>
                    @if (Model.Incidencias.Any())
                    {
                        foreach (var i in Model.Incidencias)
                        {
                            <tr>
                                <td>@i.CodigoIncidencia</td><td>@i.TipoIncidencia</td><td>@i.FechaHora.ToString("dd/MM/yyyy HH:mm")</td><td>@i.Prioridad</td><td>@i.EstadoIncidencia</td>
                            </tr>
                        }
                    }
                    else { <tr><td colspan="5" class="text-center text-muted">No hay incidencias de tu operación.</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>
