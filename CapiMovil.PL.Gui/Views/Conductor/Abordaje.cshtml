@model CapiMovil.PL.Gui.Models.ViewModels.ConductorAbordajeViewModel
@{
    ViewData["Title"] = "Abordaje";
}

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <h2 class="fw-bold mb-3">Registrar abordaje</h2>
        @if (Model.RecorridoActivo == null)
        {
            <div class="alert alert-warning mb-0">No tienes recorrido activo. Debes iniciar un recorrido para registrar abordajes.</div>
        }
        else
        {
            <p><strong>Recorrido activo:</strong> @Model.RecorridoActivo.CodigoRecorrido - @Model.RecorridoActivo.Ruta?.Nombre</p>
            <form asp-action="RegistrarAbordaje" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <div class="col-md-4">
                    <label class="form-label">Estudiante</label>
                    <select asp-for="IdEstudiante" asp-items="Model.Estudiantes" class="form-select">
                        <option value="">-- Seleccione --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Tipo</label>
                    <select asp-for="TipoEvento" asp-items="Model.TiposEvento" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Paradero</label>
                    <select asp-for="IdParadero" asp-items="Model.Paraderos" class="form-select">
                        <option value="">-- Opcional --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fecha/Hora</label>
                    <input asp-for="FechaHora" class="form-control" type="datetime-local" value="@Model.FechaHora.ToString("yyyy-MM-ddTHH:mm")" />
                </div>
                <div class="col-12">
                    <label class="form-label">Observación</label>
                    <input asp-for="Observacion" class="form-control" />
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">Registrar</button>
                </div>
            </form>
        }
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <h5 class="fw-bold mb-3">Eventos de mis recorridos</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-primary"><tr><th>Código</th><th>Tipo</th><th>Fecha/Hora</th><th>Estudiante</th><th>Observación</th></tr></thead>
                <tbody>
                    @if (Model.Eventos.Any())
                    {
                        foreach (var e in Model.Eventos)
                        {
                            <tr>
                                <td>@e.CodigoEvento</td><td>@e.TipoEvento</td><td>@e.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@e.Estudiante?.Nombres @e.Estudiante?.ApellidoPaterno</td><td>@e.Observacion</td>
                            </tr>
                        }
                    }
                    else { <tr><td colspan="5" class="text-center text-muted">No hay eventos para tus recorridos.</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>
