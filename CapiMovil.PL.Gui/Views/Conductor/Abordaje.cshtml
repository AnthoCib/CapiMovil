@model CapiMovil.PL.Gui.Models.ViewModels.ConductorAbordajeViewModel
@{
    ViewData["Title"] = "Detalle de parada y alumnos";

    var eventosPorParadero = Model.Eventos
        .Where(e => e.Paradero != null)
        .GroupBy(e => e.Paradero!.Nombre)
        .OrderBy(g => g.Key)
        .ToList();
}

<div class="conductor-shell">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1"><i class="bi bi-people-fill me-2 text-primary"></i>Detalle de parada / alumnos por parada</h1>
            <p class="text-muted mb-0">Registra abordajes y monitorea eventos por cada paradero de la ruta.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            @if (Model.RecorridoActivo == null)
            {
                <div class="alert alert-warning border-0 mb-0">
                    <i class="bi bi-exclamation-triangle me-2"></i>No tienes recorrido activo. Inicia una etapa para registrar abordajes.
                </div>
            }
            else
            {
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <span class="badge text-bg-success px-3 py-2 rounded-pill"><i class="bi bi-broadcast-pin me-1"></i>Recorrido activo</span>
                    <span class="badge text-bg-light text-primary px-3 py-2">@Model.RecorridoActivo.CodigoRecorrido</span>
                    <span class="badge text-bg-light text-dark px-3 py-2">@Model.RecorridoActivo.Ruta?.Nombre</span>
                </div>

                <form asp-action="RegistrarAbordaje" method="post" class="row g-3">
                    @Html.AntiForgeryToken()

                    <div class="col-12 col-lg-5">
                        <label class="form-label fw-semibold">Alumno</label>
                        <select asp-for="IdEstudiante" asp-items="Model.Estudiantes" class="form-select form-select-lg">
                            <option value="">-- Seleccione alumno --</option>
                        </select>
                    </div>

                    <div class="col-6 col-lg-2">
                        <label class="form-label fw-semibold">Tipo</label>
                        <select asp-for="TipoEvento" asp-items="Model.TiposEvento" class="form-select form-select-lg"></select>
                    </div>

                    <div class="col-6 col-lg-3">
                        <label class="form-label fw-semibold">Parada</label>
                        <select asp-for="IdParadero" asp-items="Model.Paraderos" class="form-select form-select-lg">
                            <option value="">-- Opcional --</option>
                        </select>
                    </div>

                    <div class="col-12 col-lg-2">
                        <label class="form-label fw-semibold">Hora</label>
                        <input asp-for="FechaHora" class="form-control form-control-lg" type="datetime-local" value="@Model.FechaHora.ToString("yyyy-MM-ddTHH:mm")" />
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">Observación</label>
                        <input asp-for="Observacion" class="form-control form-control-lg" placeholder="Comentario breve del evento" />
                    </div>

                    <div class="col-12 d-grid d-md-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg conductor-btn-lg px-4">
                            <i class="bi bi-check2-circle me-2"></i>Registrar evento
                        </button>
                        <a asp-action="Recorrido" class="btn btn-outline-secondary btn-lg conductor-btn-lg px-4">
                            <i class="bi bi-arrow-left me-2"></i>Volver al recorrido
                        </a>
                    </div>
                </form>
            }
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-xl-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h2 class="h5 fw-bold mb-1"><i class="bi bi-clock-history me-2 text-primary"></i>Últimos eventos de abordaje</h2>
                    <p class="text-muted mb-0">Listado cronológico de tus registros más recientes.</p>
                </div>
                <div class="card-body px-4 pb-4">
                    @if (!Model.Eventos.Any())
                    {
                        <div class="text-muted">No hay eventos registrados para tus recorridos.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th>Alumno</th>
                                        <th>Parada</th>
                                        <th>Tipo</th>
                                        <th>Fecha</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var e in Model.Eventos.Take(12))
                                    {
                                        <tr>
                                            <td>@e.Estudiante?.Nombres @e.Estudiante?.ApellidoPaterno</td>
                                            <td>@(e.Paradero?.Nombre ?? "Sin parada")</td>
                                            <td>
                                                <span class="badge @(e.TipoEvento == "SUBIDA" ? "text-bg-success" : e.TipoEvento == "BAJADA" ? "text-bg-primary" : "text-bg-secondary")">
                                                    @e.TipoEvento
                                                </span>
                                            </td>
                                            <td>@e.FechaHora.ToString("dd/MM HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h2 class="h5 fw-bold mb-1"><i class="bi bi-signpost-split me-2 text-primary"></i>Alumnos por parada</h2>
                    <p class="text-muted mb-0">Consolidado rápido por paradero según eventos registrados.</p>
                </div>
                <div class="card-body px-4 pb-4">
                    @if (!eventosPorParadero.Any())
                    {
                        <div class="text-muted">Todavía no hay eventos asociados a paraderos.</div>
                    }
                    else
                    {
                        <div class="conductor-stop-list">
                            @foreach (var grupo in eventosPorParadero)
                            {
                                var subidas = grupo.Count(x => x.TipoEvento == "SUBIDA");
                                var bajadas = grupo.Count(x => x.TipoEvento == "BAJADA");
                                <div class="conductor-stop-item">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h3 class="h6 fw-bold mb-0">@grupo.Key</h3>
                                        <span class="badge text-bg-light">@grupo.Count() eventos</span>
                                    </div>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <span class="badge text-bg-success">Subidas: @subidas</span>
                                        <span class="badge text-bg-primary">Bajadas: @bajadas</span>
                                    </div>
                                    <div class="small text-muted mt-2">
                                        @string.Join(", ", grupo.Take(4).Select(x => $"{x.Estudiante?.Nombres} {x.Estudiante?.ApellidoPaterno}"))
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
