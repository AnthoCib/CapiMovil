@model CapiMovil.BL.BE.IncidenciaBE

<article class="conductor-alert-item">
    <div class="d-flex justify-content-between align-items-start gap-2">
        <h3 class="h6 fw-semibold mb-1">@Model.TipoIncidencia</h3>
        <span class="badge rounded-pill text-bg-danger-subtle text-danger-emphasis">Alerta</span>
    </div>
    <p class="small text-muted mb-2">@Model.Descripcion</p>
    <p class="x-small text-muted mb-0"><i class="bi bi-clock me-1"></i>@Model.FechaHora.ToString("dd/MM/yyyy HH:mm")</p>
</article>
