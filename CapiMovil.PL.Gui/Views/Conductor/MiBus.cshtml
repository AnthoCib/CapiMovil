@model CapiMovil.BL.BE.BusBE?
@{
    ViewData["Title"] = "Mi Bus";
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <h2 class="fw-bold mb-3">Mi Bus</h2>

        @if (Model == null)
        {
            <div class="alert alert-warning mb-0">No tienes un bus asignado mediante un recorrido activo.</div>
        }
        else
        {
            <div class="row g-3">
                <div class="col-md-4"><strong>Código:</strong> @Model.CodigoBus</div>
                <div class="col-md-4"><strong>Placa:</strong> @Model.Placa</div>
                <div class="col-md-4"><strong>Marca/Modelo:</strong> @Model.Marca @Model.Modelo</div>
                <div class="col-md-4"><strong>Capacidad:</strong> @Model.Capacidad</div>
                <div class="col-md-4"><strong>Operación:</strong> @Model.EstadoOperacion</div>
                <div class="col-md-4"><strong>Estado:</strong> @(Model.Estado ? "Activo" : "Inactivo")</div>
            </div>
        }
    </div>
</div>
