@model List<CapiMovil.BL.BE.EstudianteBE>
@{
    ViewData["Title"] = "Mis Hijos";
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <h2 class="fw-bold mb-3">Mis Hijos</h2>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-primary">
                    <tr>
                        <th>Código</th>
                        <th>Nombre completo</th>
                        <th>Grado</th>
                        <th>Sección</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.CodigoEstudiante</td>
                                <td>@item.NombreCompleto</td>
                                <td>@item.Grado</td>
                                <td>@item.Seccion</td>
                                <td>@(item.Estado ? "Activo" : "Inactivo")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center text-muted">No hay estudiantes asociados.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
