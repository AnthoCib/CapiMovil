@model CapiMovil.BL.BE.NotificacionBE
@{
    ViewData["Title"] = "Detalle de Notificación";

    string estadoLectura = Model.Leido ? "Leída" : "No leída";
    string claseLectura = Model.Leido ? "text-bg-success" : "text-bg-warning text-dark";
    string estudiante = !string.IsNullOrWhiteSpace(Model.NombreEstudiante)
        ? Model.NombreEstudiante!
        : "No asociado";
    string codigoEstudiante = !string.IsNullOrWhiteSpace(Model.CodigoEstudiante)
        ? Model.CodigoEstudiante!
        : "No disponible";
}

<div class="pf-page">
    <section class="pf-card p-3 p-lg-4">
        @await Html.PartialAsync("_SectionHeader", ("Detalle de notificación", "Información completa y trazabilidad del mensaje recibido.", "bi-envelope-open"))

        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
            <span class="badge @claseLectura px-3 py-2"><i class="bi bi-envelope-check me-1"></i>@estadoLectura</span>
            <span class="badge text-bg-light border px-3 py-2"><i class="bi bi-tag me-1"></i>@Model.TipoNotificacion</span>
            <span class="badge text-bg-light border px-3 py-2"><i class="bi bi-broadcast me-1"></i>@Model.Canal</span>
            <span class="badge text-bg-light border px-3 py-2"><i class="bi bi-upc-scan me-1"></i>@Model.CodigoNotificacion</span>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-12 col-xl-8">
                <div class="pf-data-cell h-100">
                    <small class="text-uppercase">Título</small>
                    <div class="fw-semibold fs-5">@Model.Titulo</div>
                </div>
            </div>
            <div class="col-12 col-xl-4">
                <div class="pf-data-cell h-100">
                    <small class="text-uppercase">Fecha de envío</small>
                    <div class="fw-semibold">@Model.FechaEnvio.ToString("dd/MM/yyyy HH:mm")</div>
                    <div class="text-muted small">@Model.FechaEnvio.ToString("dddd, dd 'de' MMMM", new System.Globalization.CultureInfo("es-PE"))</div>
                </div>
            </div>
        </div>

        <div class="pf-data-cell mb-3">
            <small class="text-uppercase">Mensaje</small>
            <div class="mt-2" style="white-space: pre-wrap;">@Model.Mensaje</div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-md-6">
                <div class="pf-data-cell h-100">
                    <small class="text-uppercase">Estudiante relacionado</small>
                    <div class="fw-semibold">@estudiante</div>
                    <div class="text-muted small">Código: @codigoEstudiante</div>
                </div>
            </div>
            <div class="col-12 col-md-6">
                <div class="pf-data-cell h-100">
                    <small class="text-uppercase">Trazabilidad</small>
                    <ul class="list-unstyled mb-0 mt-1 small">
                        <li><i class="bi bi-calendar-event me-1 text-primary"></i>Creada: @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</li>
                        <li>
                            <i class="bi bi-pencil-square me-1 text-info"></i>
                            Actualizada: @(Model.FechaActualizacion.HasValue ? Model.FechaActualizacion.Value.ToString("dd/MM/yyyy HH:mm") : "Sin actualizaciones")
                        </li>
                        <li>
                            <i class="bi bi-envelope-open me-1 text-success"></i>
                            Leída: @(Model.FechaLectura.HasValue ? Model.FechaLectura.Value.ToString("dd/MM/yyyy HH:mm") : "Pendiente")
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Notificaciones" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Volver a notificaciones
            </a>
            @if (Model.IdEstudiante.HasValue)
            {
                <a asp-action="DetalleHijo" asp-route-idEstudiante="@Model.IdEstudiante" class="btn btn-outline-primary">
                    <i class="bi bi-person-vcard me-1"></i>Ver estudiante relacionado
                </a>
            }
        </div>
    </section>
</div>
