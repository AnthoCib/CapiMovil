@model CapiMovil.PL.Gui.Models.ViewModels.PadreRegistrarEstudianteViewModel
@{
    ViewData["Title"] = "Registrar Estudiante";
    string fotoActual = string.IsNullOrWhiteSpace(Model.FotoUrl) ? "/images/student-placeholder.svg" : Model.FotoUrl!;
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
          crossorigin="" />
}

<div class="row g-4">
    <div class="col-xl-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h2 class="h4 fw-bold mb-1"><i class="bi bi-person-plus-fill text-primary me-2"></i>Registrar estudiante</h2>
                <p class="text-muted mb-0">Registra los datos personales, ubicación y foto del estudiante.</p>
            </div>
            <div class="card-body">
                <form asp-action="RegistrarHijo" method="post" enctype="multipart/form-data" class="row g-3">
                    @Html.AntiForgeryToken()
                    <input asp-for="FotoUrl" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="card border-0 bg-light-subtle mb-3">
                        <div class="card-body">
                            <h3 class="h6 text-uppercase text-muted mb-3">Datos generales</h3>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label asp-for="Nombres" class="form-label"></label>
                                    <input asp-for="Nombres" class="form-control" />
                                    <span asp-validation-for="Nombres" class="text-danger"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="ApellidoPaterno" class="form-label"></label>
                                    <input asp-for="ApellidoPaterno" class="form-control" />
                                    <span asp-validation-for="ApellidoPaterno" class="text-danger"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="ApellidoMaterno" class="form-label"></label>
                                    <input asp-for="ApellidoMaterno" class="form-control" />
                                    <span asp-validation-for="ApellidoMaterno" class="text-danger"></span>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="DNI" class="form-label"></label>
                                    <input asp-for="DNI" class="form-control" maxlength="8" />
                                    <span asp-validation-for="DNI" class="text-danger"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="FechaNacimiento" class="form-label"></label>
                                    <input asp-for="FechaNacimiento" class="form-control" />
                                    <span asp-validation-for="FechaNacimiento" class="text-danger"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="Genero" class="form-label"></label>
                                    <select asp-for="Genero" class="form-select">
                                        <option value="">Seleccione</option>
                                        <option value="M">Masculino</option>
                                        <option value="F">Femenino</option>
                                    </select>
                                    <span asp-validation-for="Genero" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Grado" class="form-label"></label>
                                    <input asp-for="Grado" class="form-control" />
                                    <span asp-validation-for="Grado" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Seccion" class="form-label"></label>
                                    <input asp-for="Seccion" class="form-control" />
                                    <span asp-validation-for="Seccion" class="text-danger"></span>
                                </div>

                                <div class="col-12">
                                    <label asp-for="Direccion" class="form-label"></label>
                                    <input asp-for="Direccion" class="form-control" placeholder="Se actualiza al mover el marcador" />
                                    <small id="infoDireccionEstudiante" class="text-muted d-block mt-1">Puedes ajustar la dirección manualmente si deseas mayor detalle.</small>
                                    <span asp-validation-for="Direccion" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Observaciones" class="form-label"></label>
                                    <textarea asp-for="Observaciones" class="form-control" rows="2"></textarea>
                                    <span asp-validation-for="Observaciones" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="FotoArchivo" class="form-label"></label>
                                    <input asp-for="FotoArchivo" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" data-preview-target="previewFotoEstudiante" />
                                    <small class="text-muted">Carga una foto del estudiante (opcional).</small>
                                    <span asp-validation-for="FotoArchivo" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Registrar estudiante</button>
                        <a asp-action="MisHijos" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h3 class="h5 fw-bold mb-1"><i class="bi bi-geo-alt-fill text-danger me-2"></i>Ubicación de casa</h3>
                <p class="text-muted mb-0">Marca la ubicación del domicilio del estudiante.</p>
            </div>
            <div class="card-body d-flex flex-column gap-3">
                <button type="button" id="btnGeolocalizarEstudiante" class="btn btn-outline-primary">
                    <i class="bi bi-crosshair me-1"></i>Usar mi ubicación actual
                </button>

                <div id="mapEstudiante" class="capi-map capi-map-sm"></div>

                <span id="infoCoordsEstudiante" class="badge text-bg-light border capi-coords-badge align-self-start">Latitud: -- | Longitud: --</span>

                <div class="row g-2">
                    <div class="col-6">
                        <label asp-for="LatitudCasa" class="form-label"></label>
                        <input asp-for="LatitudCasa" class="form-control" step="any" />
                        <span asp-validation-for="LatitudCasa" class="text-danger"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="LongitudCasa" class="form-label"></label>
                        <input asp-for="LongitudCasa" class="form-control" step="any" />
                        <span asp-validation-for="LongitudCasa" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h3 class="h5 fw-bold mb-1"><i class="bi bi-image text-success me-2"></i>Foto del estudiante</h3>
                <p class="text-muted mb-0">Vista previa de la foto seleccionada.</p>
            </div>
            <div class="card-body">
                <img id="previewFotoEstudiante" src="@fotoActual" class="img-fluid rounded border estudiante-foto-preview" alt="Foto del estudiante" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            CapiMovilMaps.createPointPicker({
                mapId: 'mapEstudiante',
                latInputId: 'LatitudCasa',
                lngInputId: 'LongitudCasa',
                geolocateButtonId: 'btnGeolocalizarEstudiante',
                coordinatesInfoId: 'infoCoordsEstudiante',
                addressInputId: 'Direccion',
                addressInfoId: 'infoDireccionEstudiante',
                defaultCenter: [-12.046374, -77.042793]
            });

            CapiMovilMaps.bindImagePreview('FotoArchivo', 'previewFotoEstudiante');
        });
    </script>
}
