@model List<CapiMovil.BL.BE.PadreFamiliaBE>

@{
    ViewData["Title"] = "Padres de Familia";
}

<div class="list-shell">
    <div class="list-toolbar mb-4">
        <div>
            <h2 class="list-title mb-1">Lista de Padres de Familia</h2>
            <p class="list-subtitle mb-0">Gestión de tutores y datos de contacto.</p>
        </div>
        <a asp-action="Crear" class="btn btn-primary list-btn-primary"><i class="bi bi-plus-circle me-1"></i>Nuevo padre</a>
    </div>

    @if (TempData["ok"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            @TempData["ok"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="list-table-card">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table list-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Nombre completo</th>
                            <th>DNI</th>
                            <th>Teléfono</th>
                            <th>Correo</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="list-code">@item.CodigoPadre</span></td>
                                <td>@item.NombreCompleto</td>
                                <td>@item.DNI</td>
                                <td>@item.Telefono</td>
                                <td>@item.CorreoContacto</td>
                                <td><span class="badge @(item.Estado ? "text-bg-success" : "text-bg-secondary")">@(item.Estado ? "Activo" : "Inactivo")</span></td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-1">
                                        <a asp-action="Editar" asp-route-id="@item.IdPadre" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil-square"></i></a>
                                        <form asp-action="Eliminar" asp-route-id="@item.IdPadre" method="post" class="d-inline form-eliminar" data-confirm data-confirm-title="¿Estás seguro?" data-confirm-text="Esta acción eliminará el padre de familia seleccionado." data-confirm-icon="warning" data-confirm-confirm-text="Sí, eliminar" data-confirm-cancel-text="Cancelar">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            @await Html.PartialAsync("_ListEmptyState", ("Sin padres de familia", "No hay registros disponibles.", "bi-people"))
        }
    </div>
</div>
