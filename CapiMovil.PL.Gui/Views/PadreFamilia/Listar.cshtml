@model List<CapiMovil.BL.BE.PadreFamiliaBE>

@{
    ViewData["Title"] = "Padres de Familia";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0">Lista de Padres de Familia</h2>
    <a asp-action="Crear" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Nuevo Padre</a>
</div>

@if (TempData["ok"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        @TempData["ok"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        @TempData["error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card card-soft">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-primary">
                    <tr>
                        <th>Código</th>
                        <th>Nombre completo</th>
                        <th>DNI</th>
                        <th>Teléfono</th>
                        <th>Correo</th>
                        <th>Estado</th>
                        <th class="text-center" style="width: 180px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.CodigoPadre</td>
                                <td>@item.NombreCompleto</td>
                                <td>@item.DNI</td>
                                <td>@item.Telefono</td>
                                <td>@item.CorreoContacto</td>
                                <td>
                                    @if (item.Estado)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Editar" asp-route-id="@item.IdPadre" class="btn btn-warning btn-sm btn-action"><i class="bi bi-pencil-square me-1"></i>Editar</a>

                                    <form asp-action="Eliminar" asp-route-id="@item.IdPadre" method="post" class="d-inline form-eliminar">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm btn-action"><i class="bi bi-trash me-1"></i>Eliminar</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">No hay registros.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
