@{
    ViewData["Title"] = "Panel de Padre de Familia";
}

<div class="mb-4">
    <h2 class="fw-bold">Bienvenido, @ViewBag.PadreNombre</h2>
    <p class="text-muted mb-0">Consulte información importante de sus hijos y del transporte escolar.</p>
</div>

<div class="row g-3">
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h6 class="text-muted">Hijos asociados</h6>
                <h3 class="fw-bold">@ViewBag.CantidadHijos</h3>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h6 class="text-muted">Notificaciones pendientes</h6>
                <h3 class="fw-bold">@ViewBag.CantidadNotificaciones</h3>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-md-6 col-xl-3">
        <a class="card text-decoration-none shadow-sm border-0 h-100" asp-controller="PadreFamilia" asp-action="MisHijos">
            <div class="card-body">
                <h5 class="card-title">Mis hijos</h5>
                <p class="card-text text-muted">Vea el detalle de estudiantes asociados.</p>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-3">
        <a class="card text-decoration-none shadow-sm border-0 h-100" asp-controller="PadreFamilia" asp-action="MisEventos">
            <div class="card-body">
                <h5 class="card-title">Eventos de abordaje</h5>
                <p class="card-text text-muted">Consulte eventos recientes de transporte.</p>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-3">
        <a class="card text-decoration-none shadow-sm border-0 h-100" asp-controller="PadreFamilia" asp-action="Notificaciones">
            <div class="card-body">
                <h5 class="card-title">Notificaciones</h5>
                <p class="card-text text-muted">Revise avisos enviados por el sistema.</p>
            </div>
        </a>
    </div>
</div>
