@model CapiMovil.PL.Gui.Models.ViewModels.PadreDashboardViewModel
@{
    ViewData["Title"] = "Panel de Padre de Familia";
}

<div class="pf-page">
    <section class="pf-hero mb-3">
        <h1 class="h4 pf-title mb-1">Hola, @Model.NombrePadre</h1>
        <p class="pf-subtitle mb-0">Aquí tienes el resumen diario del transporte y seguimiento de tus hijos.</p>
    </section>

    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <div class="pf-kpi"><p class="pf-kpi-label mb-1">Hijos asociados</p><p class="pf-kpi-value mb-0">@Model.CantidadHijos</p></div>
        </div>
        <div class="col-md-4">
            <div class="pf-kpi"><p class="pf-kpi-label mb-1">Notificaciones no leídas</p><p class="pf-kpi-value mb-0">@Model.CantidadNotificacionesPendientes</p></div>
        </div>
        <div class="col-md-4">
            <div class="pf-kpi"><p class="pf-kpi-label mb-1">Eventos recientes (7 días)</p><p class="pf-kpi-value mb-0">@Model.CantidadEventosRecientes</p></div>
        </div>
    </div>

    <section class="pf-card p-3">
        @await Html.PartialAsync("_SectionHeader", ("Accesos rápidos", "Consulta la información clave de forma inmediata.", "bi-lightning-charge"))

        <div class="row g-2">
            <div class="col-sm-6 col-lg-3"><a class="pf-action-link" asp-action="MisHijos"><i class="bi bi-people me-2"></i>Mis Hijos</a></div>
            <div class="col-sm-6 col-lg-3"><a class="pf-action-link" asp-action="Notificaciones"><i class="bi bi-bell me-2"></i>Notificaciones</a></div>
            <div class="col-sm-6 col-lg-3"><a class="pf-action-link" asp-action="Seguimiento"><i class="bi bi-geo-alt me-2"></i>Seguimiento</a></div>
            <div class="col-sm-6 col-lg-3"><a class="pf-action-link" asp-controller="Usuario" asp-action="MiPerfil"><i class="bi bi-person-circle me-2"></i>Mi Perfil</a></div>
            <div class="col-sm-6 col-lg-3"><a class="pf-action-link" asp-action="MiRuta"><i class="bi bi-signpost-2 me-2"></i>Mi Ruta</a></div>
            <div class="col-sm-6 col-lg-3"><a class="pf-action-link" asp-action="MiParadero"><i class="bi bi-pin-map me-2"></i>Mi Paradero</a></div>
            <div class="col-sm-6 col-lg-3"><a class="pf-action-link" asp-action="MisEventos"><i class="bi bi-clock-history me-2"></i>Eventos</a></div>
            <div class="col-sm-6 col-lg-3"><a class="pf-action-link" asp-action="Incidencias"><i class="bi bi-exclamation-triangle me-2"></i>Incidencias</a></div>
        </div>
    </section>
</div>
