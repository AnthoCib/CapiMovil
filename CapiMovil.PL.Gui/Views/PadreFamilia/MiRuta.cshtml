@model List<CapiMovil.PL.Gui.Models.ViewModels.PadreRutaInfoViewModel>
@{
    ViewData["Title"] = "Mi Ruta";
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <h2 class="fw-bold mb-3">Rutas y transporte de mis hijos</h2>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-primary">
                    <tr><th>Estudiante</th><th>Ruta</th><th>Recorrido</th><th>Bus</th><th>Conductor</th><th>Estado</th></tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.CodigoEstudiante - @item.NombreEstudiante</td>
                                <td>@item.CodigoRuta - @item.NombreRuta</td>
                                <td>@item.CodigoRecorrido<br/><small class="text-muted">@item.FechaRecorrido?.ToString("dd/MM/yyyy")</small></td>
                                <td>@item.PlacaBus</td>
                                <td>@item.NombreConductor</td>
                                <td>@item.EstadoRecorrido</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center text-muted">No hay rutas asociadas a tus hijos.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
