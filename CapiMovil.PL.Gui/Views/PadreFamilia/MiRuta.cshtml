@model List<CapiMovil.PL.Gui.Models.ViewModels.PadreRutaInfoViewModel>
@{
    ViewData["Title"] = "Mi Ruta";
}

<div class="pf-page">
    <section class="pf-card p-3">
        @await Html.PartialAsync("_SectionHeader", ("Rutas y transporte", "Detalle de ruta, recorrido y unidad asignada por estudiante.", "bi-signpost-2"))

        @if (Model.Any())
        {
            <div class="row g-3">
                @foreach (var item in Model)
                {
                    <div class="col-md-6">
                        <article class="pf-student-card h-100">
                            <strong>@item.NombreEstudiante</strong>
                            <div class="pf-student-meta mb-2">@item.CodigoEstudiante</div>
                            <div class="pf-data-grid">
                                <div class="pf-data-cell"><small>Ruta</small>@item.CodigoRuta - @item.NombreRuta</div>
                                <div class="pf-data-cell"><small>Recorrido</small>@(item.CodigoRecorrido ?? "Sin recorrido asignado hoy")</div>
                                <div class="pf-data-cell"><small>Bus</small>@(item.PlacaBus ?? "No disponible")</div>
                                <div class="pf-data-cell"><small>Conductor</small>@(item.NombreConductor ?? "No disponible")</div>
                                <div class="pf-data-cell"><small>Estado</small>@(item.EstadoRecorrido ?? "No disponible")</div>
                            </div>
                        </article>
                    </div>
                }
            </div>
        }
        else
        {
            @await Html.PartialAsync("_EmptyState", ("Sin rutas asociadas", "No hay rutas activas asociadas a tus hijos.", "bi-map"))
        }
    </section>
</div>
