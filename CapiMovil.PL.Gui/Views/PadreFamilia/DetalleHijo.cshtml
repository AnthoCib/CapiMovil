@model CapiMovil.PL.Gui.Models.ViewModels.PadreHijoDetalleViewModel
@{
    ViewData["Title"] = "Detalle de Hijo";
}

@if (Model.Estudiante == null)
{
    <div class="alert alert-warning">No se encontró información del estudiante.</div>
}
else
{
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            <h2 class="fw-bold mb-3">@Model.Estudiante.CodigoEstudiante - @Model.Estudiante.NombreCompleto</h2>
            <div class="row g-2">
                <div class="col-md-4"><strong>Grado:</strong> @Model.Estudiante.Grado</div>
                <div class="col-md-4"><strong>Sección:</strong> @Model.Estudiante.Seccion</div>
                <div class="col-md-4"><strong>DNI:</strong> @Model.Estudiante.DNI</div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            <h5 class="fw-bold">Ruta y Paraderos</h5>
            <p><strong>Ruta:</strong> @Model.RutaAsignada?.Ruta?.CodigoRuta - @Model.RutaAsignada?.Ruta?.Nombre</p>
            <p><strong>Paradero subida:</strong> @Model.ParaderoSubida?.Nombre (@Model.ParaderoSubida?.Direccion)</p>
            <p><strong>Paradero bajada:</strong> @Model.ParaderoBajada?.Nombre (@Model.ParaderoBajada?.Direccion)</p>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h5 class="fw-bold">Eventos recientes</h5>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-primary"><tr><th>Tipo</th><th>Fecha/Hora</th><th>Observación</th></tr></thead>
                    <tbody>
                        @if (Model.EventosRecientes.Any())
                        {
                            foreach (var e in Model.EventosRecientes)
                            {
                                <tr><td>@e.TipoEvento</td><td>@e.FechaHora.ToString("dd/MM/yyyy HH:mm")</td><td>@e.Observacion</td></tr>
                            }
                        }
                        else { <tr><td colspan="3" class="text-center text-muted">Sin eventos.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
