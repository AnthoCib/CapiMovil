@model CapiMovil.PL.Gui.Models.ViewModels.PadreFamiliaFormViewModel

@{
    ViewData["Title"] = "Crear Padre de Familia";
}

<div class="row justify-content-center">
    <div class="col-lg-9 col-xl-8">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4 p-md-5">
                <div class="mb-4">
                    <h2 class="fw-bold mb-1">Crear Padre de Familia</h2>
                    <p class="text-muted mb-0">
                        Complete la información requerida para registrar un nuevo padre de familia.
                    </p>
                </div>

                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="alert alert-info border-0 rounded-3">
                        <strong>Código automático:</strong> el código del padre de familia se generará automáticamente al guardar el registro.
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Código Padre</label>
                        <input class="form-control bg-light" value="Se generará automáticamente" disabled />
                    </div>

                    <hr class="my-4" />

                    <div class="mb-3">
                        <h5 class="fw-bold">Datos de vinculación</h5>
                        <p class="text-muted small mb-0">Asocie opcionalmente este registro a un usuario existente.</p>
                    </div>

                    <div class="mb-4">
                        <label asp-for="IdUsuario" class="form-label fw-semibold"></label>
                        <select asp-for="IdUsuario" asp-items="Model.Usuarios" class="form-select">
                            <option value="">-- Seleccione un usuario --</option>
                        </select>
                        <span asp-validation-for="IdUsuario" class="text-danger small"></span>
                    </div>

                    <hr class="my-4" />

                    <div class="mb-3">
                        <h5 class="fw-bold">Datos personales</h5>
                        <p class="text-muted small mb-0">Ingrese los datos de identificación del padre de familia.</p>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Nombres" class="form-label fw-semibold"></label>
                        <input asp-for="Nombres" class="form-control" placeholder="Ingrese los nombres" />
                        <span asp-validation-for="Nombres" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ApellidoPaterno" class="form-label fw-semibold"></label>
                            <input asp-for="ApellidoPaterno" class="form-control" placeholder="Ingrese el apellido paterno" />
                            <span asp-validation-for="ApellidoPaterno" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="ApellidoMaterno" class="form-label fw-semibold"></label>
                            <input asp-for="ApellidoMaterno" class="form-control" placeholder="Ingrese el apellido materno" />
                            <span asp-validation-for="ApellidoMaterno" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DNI" class="form-label fw-semibold"></label>
                            <input asp-for="DNI" class="form-control" maxlength="8" placeholder="Ingrese el DNI" />
                            <span asp-validation-for="DNI" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Telefono" class="form-label fw-semibold"></label>
                            <input asp-for="Telefono" class="form-control" placeholder="Ingrese el teléfono principal" />
                            <span asp-validation-for="Telefono" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="mb-3">
                        <h5 class="fw-bold">Datos de contacto</h5>
                        <p class="text-muted small mb-0">Información adicional de contacto y ubicación.</p>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TelefonoAlterno" class="form-label fw-semibold"></label>
                        <input asp-for="TelefonoAlterno" class="form-control" placeholder="Ingrese un teléfono alterno" />
                        <span asp-validation-for="TelefonoAlterno" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Direccion" class="form-label fw-semibold"></label>
                        <input asp-for="Direccion" class="form-control" placeholder="Ingrese la dirección" />
                        <span asp-validation-for="Direccion" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="CorreoContacto" class="form-label fw-semibold"></label>
                        <input asp-for="CorreoContacto" class="form-control" placeholder="Ingrese el correo de contacto" />
                        <span asp-validation-for="CorreoContacto" class="text-danger small"></span>
                    </div>

                    <hr class="my-4" />

                    <div class="mb-4">
                        <h5 class="fw-bold mb-3">Estado del registro</h5>
                        <div class="form-check form-switch">
                            <input asp-for="Estado" class="form-check-input" />
                            <label asp-for="Estado" class="form-check-label fw-semibold"></label>
                        </div>
                        <span asp-validation-for="Estado" class="text-danger small"></span>
                    </div>

                    <div class="d-flex flex-wrap gap-2 pt-2">
                        <button type="submit" class="btn btn-primary px-4">
                            Guardar
                        </button>
                        <a asp-action="Listar" class="btn btn-outline-secondary px-4">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}