@model List<CapiMovil.BL.BE.NotificacionBE>
@{
    ViewData["Title"] = "Notificaciones";
}

<div class="pf-page">
    <section class="pf-card p-3">
        @await Html.PartialAsync("_SectionHeader", ("Notificaciones", "Mantente informado sobre abordajes, alertas e incidencias.", "bi-bell"))

        @if (Model.Any())
        {
            <div class="d-flex flex-column gap-2">
                @foreach (var item in Model)
                {
                    var badgeTipo = item.TipoNotificacion?.ToUpperInvariant() switch
                    {
                        "SUBIDA" => "pf-badge-success",
                        "BAJADA" => "pf-badge-info",
                        "ALERTA" => "pf-badge-danger",
                        "INCIDENCIA" => "pf-badge-danger",
                        "RETRASO" => "pf-badge-warning",
                        _ => "pf-badge-muted"
                    };

                    <article class="pf-list-item">
                        <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                            <div>
                                <h3 class="h6 mb-1">@item.Titulo</h3>
                                <p class="pf-student-meta mb-1">@item.Canal · @item.FechaEnvio.ToString("dd/MM/yyyy HH:mm")</p>
                                <span class="pf-badge-soft @badgeTipo">@(item.TipoNotificacion ?? "General")</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                @if (item.Leido)
                                {
                                    <span class="pf-badge-soft pf-badge-success">Leída</span>
                                }
                                else
                                {
                                    <form asp-action="MarcarNotificacionLeida" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="idNotificacion" value="@item.IdNotificacion" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-check2-circle me-1"></i>Marcar leída</button>
                                    </form>
                                }

                                <a asp-action="DetalleNotificacion" asp-route-idNotificacion="@item.IdNotificacion" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye me-1"></i>Detalle
                                </a>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            @await Html.PartialAsync("_EmptyState", ("Sin notificaciones", "No hay notificaciones disponibles por el momento.", "bi-bell-slash"))
        }
    </section>
</div>
