@model CapiMovil.PL.Gui.Models.ViewModels.UsuarioFormViewModel

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card card-soft">
            <div class="card-body">
                <h2 class="page-title mb-4">Editar Usuario</h2>

                <form asp-action="Editar" method="post">
                    @Html.AntiForgeryToken()

                    <input asp-for="IdUsuario" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="CodigoUsuario" class="form-label"></label>
                        <input asp-for="CodigoUsuario" class="form-control" readonly />
                    </div>

                    <div class="mb-3">
                        <label asp-for="IdRol" class="form-label"></label>
                        <select asp-for="IdRol" asp-items="Model.Roles" class="form-select">
                            <option value="">Seleccione un rol</option>
                        </select>
                        <span asp-validation-for="IdRol" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label"></label>
                        <input asp-for="Username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Correo" class="form-label"></label>
                        <input asp-for="Correo" class="form-control" />
                        <span asp-validation-for="Correo" class="text-danger"></span>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input asp-for="Estado" class="form-check-input" />
                        <label asp-for="Estado" class="form-check-label"></label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Actualizar</button>
                        <a asp-action="Listar" class="btn btn-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}