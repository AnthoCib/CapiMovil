@model CapiMovil.PL.Gui.Models.ViewModels.UsuarioPasswordViewModel

@{
    ViewData["Title"] = "Cambiar Contraseña";
}

<div class="list-shell">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <section class="pf-card p-3 app-surface">
                <h2 class="h5 pf-title mb-1 app-section-title">Cambiar contraseña</h2>
                <p class="pf-subtitle mb-3 app-section-subtitle">Actualiza tu credencial de acceso de forma segura.</p>

                <form asp-action="CambiarPassword" method="post" data-disable-on-submit data-confirm data-confirm-title="¿Cambiar contraseña?" data-confirm-text="Se actualizará tu credencial de acceso inmediatamente." data-confirm-icon="question" data-confirm-confirm-text="Sí, cambiar" data-confirm-cancel-text="Cancelar">
                    @Html.AntiForgeryToken()

                    <input asp-for="IdUsuario" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger ux-validation-summary"></div>

                    <div class="mb-3">
                        <label asp-for="CodigoUsuario" class="form-label"></label>
                        <input asp-for="CodigoUsuario" class="form-control" readonly />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label"></label>
                        <input asp-for="Username" class="form-control" readonly />
                    </div>

                    <div class="mb-3">
                        <label asp-for="PasswordNueva" class="form-label"></label>
                        <input asp-for="PasswordNueva" class="form-control" />
                        <span asp-validation-for="PasswordNueva" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmarPassword" class="form-label"></label>
                        <input asp-for="ConfirmarPassword" class="form-control" />
                        <span asp-validation-for="ConfirmarPassword" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" data-loading-text="Guardando..."><i class="bi bi-check2-circle me-1"></i>Guardar nueva contraseña</button>
                        <a asp-action="MiPerfil" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
