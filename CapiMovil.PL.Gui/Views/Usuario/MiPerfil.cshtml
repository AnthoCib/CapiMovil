@model CapiMovil.BL.BE.UsuarioBE
@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="pf-page">
    <section class="pf-card p-3">
        <div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
            <div>
                <h2 class="h5 pf-title mb-1">Mi Perfil</h2>
                <p class="pf-subtitle mb-0">Información de acceso y cuenta del usuario.</p>
            </div>
            <span class="pf-badge-soft @(Model.Estado ? "pf-badge-success" : "pf-badge-danger")">@(Model.Estado ? "Activo" : "Inactivo")</span>
        </div>

        <div class="pf-data-grid mb-3">
            <div class="pf-data-cell"><small>Código</small>@Model.CodigoUsuario</div>
            <div class="pf-data-cell"><small>Usuario</small>@Model.Username</div>
            <div class="pf-data-cell"><small>Correo</small>@Model.Correo</div>
            <div class="pf-data-cell"><small>Rol</small>@Model.Rol?.Nombre</div>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="CambiarPassword" class="btn btn-outline-primary"><i class="bi bi-key me-1"></i>Cambiar contraseña</a>
        </div>
    </section>
</div>
