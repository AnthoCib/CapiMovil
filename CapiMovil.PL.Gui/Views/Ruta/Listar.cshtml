@model List<CapiMovil.BL.BE.RutaBE>

@{
    ViewData["Title"] = "Lista de Rutas";
}

<div class="list-shell">
    <div class="list-toolbar mb-4">
        <div>
            <h2 class="list-title mb-1">Lista de Rutas</h2>
            <p class="list-subtitle mb-0">Configuración de rutas y horarios operativos.</p>
        </div>
        <a asp-action="Crear" class="btn btn-primary list-btn-primary"><i class="bi bi-plus-circle me-1"></i>Nueva ruta</a>
    </div>

    <div class="list-table-card">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table list-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Nombre</th>
                            <th>Turno</th>
                            <th>Horario</th>
                            <th>Estado ruta</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="list-code">@item.CodigoRuta</span></td>
                                <td>@item.Nombre</td>
                                <td>@item.Turno</td>
                                <td>@item.HoraInicio.ToString(@"hh\:mm") - @item.HoraFin.ToString(@"hh\:mm")</td>
                                <td><span class="badge text-bg-info">@item.EstadoRuta</span></td>
                                <td><span class="badge @(item.Estado ? "text-bg-success" : "text-bg-secondary")">@(item.Estado ? "Activo" : "Inactivo")</span></td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-1">
                                        <a asp-action="Editar" asp-route-id="@item.IdRuta" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil-square"></i></a>
                                        <form asp-action="Eliminar" asp-route-id="@item.IdRuta" method="post" class="d-inline form-eliminar" data-confirm data-confirm-title="¿Estás seguro?" data-confirm-text="Esta acción eliminará la ruta seleccionada." data-confirm-icon="warning" data-confirm-confirm-text="Sí, eliminar" data-confirm-cancel-text="Cancelar">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            @await Html.PartialAsync("_ListEmptyState", ("Sin rutas", "No hay rutas registradas.", "bi-signpost"))
        }
    </div>
</div>
