@model CapiMovil.PL.Gui.Models.ViewModels.RutaFormViewModel

@{
    ViewData["Title"] = "Registrar Ruta";
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
          crossorigin="" />
}

<div class="row g-4">
    <div class="col-xl-7">
        <div class="card card-soft h-100">
            <div class="card-body">
                <h2 class="page-title mb-4">Registrar Ruta</h2>

                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Nombre" class="form-label"></label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Descripcion" class="form-label"></label>
                            <textarea asp-for="Descripcion" class="form-control"></textarea>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Turno" class="form-label"></label>
                            <select asp-for="Turno" asp-items="Model.Turnos" class="form-select"></select>
                            <span asp-validation-for="Turno" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="HoraInicio" class="form-label"></label>
                            <input asp-for="HoraInicio" class="form-control" />
                            <span asp-validation-for="HoraInicio" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="HoraFin" class="form-label"></label>
                            <input asp-for="HoraFin" class="form-control" />
                            <span asp-validation-for="HoraFin" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DireccionInicio" class="form-label fw-semibold text-success"></label>
                            <input asp-for="DireccionInicio" class="form-control" placeholder="Se autocompleta al seleccionar INICIO en el mapa" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DireccionFin" class="form-label fw-semibold text-danger"></label>
                            <input asp-for="DireccionFin" class="form-control" placeholder="Se autocompleta al seleccionar FIN en el mapa" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PuntoInicio" class="form-label"></label>
                            <input asp-for="PuntoInicio" class="form-control" placeholder="Referencia manual de inicio" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PuntoFin" class="form-label"></label>
                            <input asp-for="PuntoFin" class="form-control" placeholder="Referencia manual de fin" />
                        </div>

                        <div class="col-md-3">
                            <label asp-for="LatitudInicio" class="form-label"></label>
                            <input asp-for="LatitudInicio" class="form-control" step="any" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="LongitudInicio" class="form-label"></label>
                            <input asp-for="LongitudInicio" class="form-control" step="any" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="LatitudFin" class="form-label"></label>
                            <input asp-for="LatitudFin" class="form-control" step="any" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="LongitudFin" class="form-label"></label>
                            <input asp-for="LongitudFin" class="form-control" step="any" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="EstadoRuta" class="form-label"></label>
                            <select asp-for="EstadoRuta" asp-items="Model.EstadosRuta" class="form-select"></select>
                            <span asp-validation-for="EstadoRuta" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input asp-for="Estado" class="form-check-input" />
                                <label asp-for="Estado" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Guardar</button>
                        <a asp-action="Listar" class="btn btn-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-5">
        <div class="card card-soft h-100">
            <div class="card-body d-flex flex-column gap-3">
                <h3 class="h5 mb-0"><i class="bi bi-map-fill me-2"></i>Mapa de ruta</h3>
                <p class="text-muted mb-1">Haz clic en el mapa para definir <strong>INICIO</strong> y <strong>FIN</strong>. Se dibuja el recorrido automáticamente.</p>

                <div class="d-flex flex-wrap gap-2">
                    <button type="button" id="btnSelectInicio" class="btn btn-outline-success btn-sm">
                        <i class="bi bi-geo-alt-fill me-1"></i>Seleccionar INICIO
                    </button>
                    <button type="button" id="btnSelectFin" class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-flag-fill me-1"></i>Seleccionar FIN
                    </button>
                    <button type="button" id="btnClearRutaMap" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-eraser me-1"></i>Limpiar
                    </button>
                </div>

                <div id="mapRutaEditor" class="capi-map capi-map-md"></div>
                <span id="infoRutaMap" class="badge text-bg-light border">Seleccione INICIO o FIN para comenzar.</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            CapiMovilMaps.createRouteEditor({
                mapId: 'mapRutaEditor',
                latInicioInputId: 'LatitudInicio',
                lngInicioInputId: 'LongitudInicio',
                dirInicioInputId: 'DireccionInicio',
                refInicioInputId: 'PuntoInicio',
                latFinInputId: 'LatitudFin',
                lngFinInputId: 'LongitudFin',
                dirFinInputId: 'DireccionFin',
                refFinInputId: 'PuntoFin',
                selectInicioButtonId: 'btnSelectInicio',
                selectFinButtonId: 'btnSelectFin',
                clearButtonId: 'btnClearRutaMap',
                infoElementId: 'infoRutaMap',
                defaultCenter: [-12.046374, -77.042793]
            });
        });
    </script>
}
