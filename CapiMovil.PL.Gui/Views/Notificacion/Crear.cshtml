@model CapiMovil.PL.Gui.Models.NotificacionFormViewModel

@{
    ViewData["Title"] = "Registrar Notificación";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Registrar Notificación</h2>
            <p class="text-muted mb-0">Completa la información de la notificación.</p>
        </div>
        <a asp-action="Listar" class="btn btn-outline-secondary">Volver</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form asp-action="Crear" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="IdPadre" class="form-label fw-semibold"></label>
                        <select asp-for="IdPadre" asp-items="Model.Padres" class="form-select">
                            <option value="">-- Seleccione un padre --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="IdEstudiante" class="form-label fw-semibold"></label>
                        <select asp-for="IdEstudiante" asp-items="Model.Estudiantes" class="form-select">
                            <option value="">-- Seleccione un estudiante --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Titulo" class="form-label fw-semibold"></label>
                        <input asp-for="Titulo" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="TipoNotificacion" class="form-label fw-semibold"></label>
                        <select asp-for="TipoNotificacion" asp-items="Model.Tipos" class="form-select"></select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Canal" class="form-label fw-semibold"></label>
                        <select asp-for="Canal" asp-items="Model.Canales" class="form-select"></select>
                    </div>
                    <div class="col-md-6 d-flex align-items-center">
                        <div class="form-check mt-4">
                            <input asp-for="Leido" class="form-check-input" />
                            <label asp-for="Leido" class="form-check-label">Marcar como leída</label>
                        </div>
                    </div>
                    <div class="col-12">
                        <label asp-for="Mensaje" class="form-label fw-semibold"></label>
                        <textarea asp-for="Mensaje" class="form-control" rows="4"></textarea>
                    </div>
                </div>

                <hr class="my-4" />

                <button type="submit" class="btn btn-success px-4">Guardar</button>
                <a asp-action="Listar" class="btn btn-light border px-4">Cancelar</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}