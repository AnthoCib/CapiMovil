@model List<CapiMovil.BL.BE.NotificacionBE>
@using Microsoft.AspNetCore.Http
@using System.Linq
@inject IHttpContextAccessor HttpContextAccessor



@{
    ViewData["Title"] = "Notificaciones";
    int total = Model?.Count ?? 0;
    int noLeidas = Model?.Count(x => !x.Leido) ?? 0;
    int leidas = Model?.Count(x => x.Leido) ?? 0;
    string rol = (HttpContextAccessor.HttpContext?.Session.GetString("RolNombre") ?? string.Empty).Trim().ToUpperInvariant();
    bool esAdmin = rol == "ADMIN" || rol == "ADMINISTRADOR";
}

<div class="list-shell">
    <div class="list-toolbar mb-4">
        <div>
            <h2 class="list-title mb-1">Gestión de Notificaciones</h2>
            <p class="list-subtitle mb-0">Seguimiento de alertas enviadas a padres y estudiantes.</p>
        </div>
        @if (!esAdmin)
        {
            <a asp-action="Crear" class="btn btn-primary list-btn-primary"><i class="bi bi-plus-circle me-1"></i>Nueva notificación</a>
        }
    </div>

    @if (TempData["ok"] != null)
    {
        <div class="alert alert-success">@TempData["ok"]</div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger">@TempData["error"]</div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-4"><div class="list-kpi-card"><small>Total</small><strong>@total</strong></div></div>
        <div class="col-md-4"><div class="list-kpi-card"><small>No leídas</small><strong class="text-warning">@noLeidas</strong></div></div>
        <div class="col-md-4"><div class="list-kpi-card"><small>Leídas</small><strong class="text-success">@leidas</strong></div></div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-3">
            @foreach (var item in Model.OrderByDescending(x => x.FechaEnvio))
            {
                <div class="col-12 col-lg-6">
                    <article class="list-entity-card h-100">
                        <header class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <div>
                                <div class="list-code">@item.CodigoNotificacion</div>
                                <h3 class="h6 mb-0">@item.Titulo</h3>
                            </div>
                            <span class="badge @(item.Leido ? "text-bg-success" : "text-bg-warning")">@(item.Leido ? "LEÍDA" : "NO LEÍDA")</span>
                        </header>

                        <div class="list-meta-grid mb-3">
                            <div><small>Tipo</small><strong>@item.TipoNotificacion</strong></div>
                            <div><small>Canal</small><strong>@item.Canal</strong></div>
                            <div><small>Padre</small><strong>@(string.IsNullOrWhiteSpace(item.NombrePadre) ? "Sin padre" : item.NombrePadre)</strong></div>
                            <div><small>Estudiante</small><strong>@(string.IsNullOrWhiteSpace(item.NombreEstudiante) ? "Sin estudiante" : item.NombreEstudiante)</strong></div>
                            <div><small>Fecha envío</small><strong>@item.FechaEnvio.ToString("dd/MM/yyyy HH:mm")</strong></div>
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            <a asp-action="Detalle" asp-route-id="@item.IdNotificacion" class="btn btn-outline-primary btn-sm"><i class="bi bi-eye me-1"></i>Ver</a>

                            @if (!esAdmin)
                            {
                                @if (!item.Leido)
                                {
                                    <form asp-action="MarcarLeida" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.IdNotificacion" />
                                        <button type="submit" class="btn btn-outline-success btn-sm"><i class="bi bi-check2 me-1"></i>Marcar leída</button>
                                    </form>
                                }

                                <form asp-action="Eliminar" method="post" class="d-inline form-eliminar">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.IdNotificacion" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Eliminar</button>
                                </form>
                            }
                        </div>
                    </article>
                </div>
            }
        </div>
    }
    else
    {
        @await Html.PartialAsync("_ListEmptyState", ("Sin notificaciones", "No hay notificaciones registradas por ahora.", "bi-bell"))
    }
</div>
