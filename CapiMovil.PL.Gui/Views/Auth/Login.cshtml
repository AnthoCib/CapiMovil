@model CapiMovil.PL.Gui.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Iniciar sesión";
}

@section Styles {
    <link rel="stylesheet" href="~/css/login-capimovil.css" asp-append-version="true" />
}

<main class="capimovil-login-page">
    <section class="capimovil-login-stage">
        <img class="capimovil-login-bg"
             src="~/images/brand/capimovil-login-bg.png"
             asp-append-version="true"
             alt="La Capimóvil Servicio Escolar" />

        <div class="capimovil-login-form-layer">
            <form asp-action="Login" method="post" class="capimovil-login-form" novalidate>
                @Html.AntiForgeryToken()

                <h1 class="capimovil-title">Bienvenido</h1>
                <p class="capimovil-subtitle">Inicia sesión para continuar</p>

                <div asp-validation-summary="ModelOnly" class="alert alert-danger capimovil-login-error"></div>

                <div class="capimovil-field capimovil-email-field">
                    <i class="bi bi-envelope"></i>
                    <input asp-for="UsuarioOCorreo"
                           class="form-control"
                           placeholder="Correo electrónico" aria-label="Usuario o correo"
                           autocomplete="username" />
                </div>
                <span asp-validation-for="UsuarioOCorreo" class="text-danger small d-block mb-2"></span>

                <div class="capimovil-field capimovil-password-field">
                    <i class="bi bi-lock"></i>
                    <input asp-for="Password"
                           id="passwordInput"
                           class="form-control"
                           placeholder="Contraseña" aria-label="Contraseña"
                           autocomplete="current-password" />

                    <button type="button"
                            class="capimovil-password-toggle"
                            id="togglePassword"
                            aria-label="Mostrar u ocultar contraseña">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger small d-block mb-2"></span>

                <div class="capimovil-login-options">
                    <label class="form-check capimovil-remember">
                        <input class="form-check-input" type="checkbox" />
                        <span class="form-check-label">Recordarme</span>
                    </label>

                    <a href="#" class="capimovil-forgot">
                        ¿Olvidaste tu contraseña?
                    </a>
                </div>

                <button type="submit" class="capimovil-submit">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Iniciar sesión
                </button>

                <p class="capimovil-secure"><i class="bi bi-shield-lock"></i> Sistema seguro</p>
            </form>
        </div>
    </section>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/login-capimovil.js" asp-append-version="true"></script>
}
