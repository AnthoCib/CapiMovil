@model CapiMovil.PL.Gui.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth-login.css" asp-append-version="true" />
}

<div class="cap-login-shell">
    <div class="container-fluid px-3 px-lg-4">
        <div class="cap-login-stage mx-auto">
            <div class="row g-0 h-100">
                <div class="col-lg-7">
                    <section class="cap-login-hero">
                        <div class="cap-cloud cap-cloud-a"></div>
                        <div class="cap-cloud cap-cloud-b"></div>
                        <div class="cap-pin"><i class="bi bi-geo-alt-fill"></i></div>
                        <div class="cap-route"></div>

                        <img src="~/images/login-school-transport.svg" class="cap-hero-logo" alt="La Capimóvil Servicio Escolar" />
                        <img src="~/images/login-school-transport.svg" class="cap-hero-main" alt="Transporte escolar Capimóvil" />
                    </section>
                </div>

                <div class="col-lg-5 d-flex align-items-center">
                    <section class="cap-login-card mx-lg-4 my-3 my-lg-0 w-100">
                        <div class="cap-card-badge"><i class="bi bi-building"></i></div>
                        <h1>Bienvenido</h1>
                        <p>Inicia sesión para continuar</p>

                        <form asp-action="Login" method="post" novalidate>
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger auth-validation-summary ux-validation-summary"></div>

                            <div class="mb-3">
                                <div class="input-group cap-input-group">
                                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                    <input asp-for="UsuarioOCorreo" class="form-control" placeholder="Correo electrónico" autocomplete="username" />
                                </div>
                                <span asp-validation-for="UsuarioOCorreo" class="text-danger small"></span>
                            </div>

                            <div class="mb-2">
                                <div class="input-group cap-input-group">
                                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                    <input asp-for="Password" id="Password" class="form-control" placeholder="Contraseña" autocomplete="current-password" />
                                    <button type="button" class="btn cap-eye" id="btnTogglePassword"><i class="bi bi-eye"></i></button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="recordarme">
                                    <label class="form-check-label" for="recordarme">Recordarme</label>
                                </div>
                                <a href="#" class="cap-link">¿Olvidaste tu contraseña?</a>
                            </div>

                            <button type="submit" class="btn cap-login-btn w-100 mb-4">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar sesión
                            </button>

                            <div class="cap-secure-note">
                                <span></span><i class="bi bi-shield-lock"></i> Sistema seguro <span></span>
                            </div>
                        </form>
                    </section>
                </div>
            </div>

            <section class="cap-benefits">
                <article><i class="bi bi-shield-check"></i><div><h3>Transporte seguro</h3><p>Viajes monitoreados</p></div></article>
                <article><i class="bi bi-person-badge"></i><div><h3>Conductores certificados</h3><p>Personal calificado</p></div></article>
                <article><i class="bi bi-heart"></i><div><h3>Confianza y compromiso</h3><p>Con nuestra comunidad</p></div></article>
                <div class="cap-deco"><i class="bi bi-backpack4"></i><i class="bi bi-book"></i></div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const input = document.getElementById('Password');
            const btn = document.getElementById('btnTogglePassword');
            if (!input || !btn) return;
            btn.addEventListener('click', function () {
                const show = input.type === 'password';
                input.type = show ? 'text' : 'password';
                btn.innerHTML = show ? '<i class="bi bi-eye-slash"></i>' : '<i class="bi bi-eye"></i>';
            });
        });
    </script>
}
