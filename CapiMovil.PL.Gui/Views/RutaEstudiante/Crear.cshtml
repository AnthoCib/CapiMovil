@model CapiMovil.PL.Gui.Models.ViewModels.RutaEstudianteFormViewModel

@{
    ViewData["Title"] = "Registrar Asignación";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h2 class="h4 fw-bold mb-1"><i class="bi bi-signpost-split-fill text-primary me-2"></i>Registrar Asignación Ruta - Estudiante</h2>
                <p class="text-muted mb-0">La asignación se crea activa por defecto.</p>
            </div>
            <div class="card-body">
                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="IdRuta" class="form-label"></label>
                            <select asp-for="IdRuta" asp-items="Model.Rutas" class="form-select">
                                <option value="">Seleccione una ruta</option>
                            </select>
                            <span asp-validation-for="IdRuta" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IdEstudiante" class="form-label"></label>
                            <select asp-for="IdEstudiante" asp-items="Model.Estudiantes" class="form-select">
                                <option value="">Seleccione un estudiante</option>
                            </select>
                            <span asp-validation-for="IdEstudiante" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="IdParaderoSubida" class="form-label"></label>
                            <select asp-for="IdParaderoSubida" asp-items="Model.ParaderosSubida" class="form-select">
                                <option value="">Seleccione un paradero</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IdParaderoBajada" class="form-label"></label>
                            <select asp-for="IdParaderoBajada" asp-items="Model.ParaderosBajada" class="form-select">
                                <option value="">Seleccione un paradero</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="FechaInicioVigencia" class="form-label"></label>
                            <input asp-for="FechaInicioVigencia" class="form-control" />
                            <span asp-validation-for="FechaInicioVigencia" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="FechaFinVigencia" class="form-label"></label>
                            <input asp-for="FechaFinVigencia" class="form-control" />
                        </div>

                        <div class="col-md-4 d-flex align-items-end">
                            <div class="alert alert-info w-100 mb-0 py-2">
                                <i class="bi bi-info-circle me-1"></i>Estado de asignación inicial: <strong>ACTIVO</strong>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Observaciones" class="form-label"></label>
                            <textarea asp-for="Observaciones" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <input asp-for="EstadoAsignacion" type="hidden" value="ACTIVO" />
                    <input asp-for="Estado" type="hidden" value="true" />

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i>Guardar</button>
                        <a asp-action="Listar" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
