@model List<CapiMovil.BL.BE.RutaEstudianteBE>

@{
    ViewData["Title"] = "Ruta - Estudiante";
}

<div class="list-shell">
    <div class="list-toolbar mb-4">
        <div>
            <h2 class="list-title mb-1">Asignaciones Ruta - Estudiante</h2>
            <p class="list-subtitle mb-0">Asignaciones activas e históricas de estudiantes por ruta.</p>
        </div>
        <a asp-action="Crear" class="btn btn-primary list-btn-primary"><i class="bi bi-plus-circle me-1"></i>Nueva asignación</a>
    </div>

    <div class="list-table-card">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table list-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Ruta</th>
                            <th>Estudiante</th>
                            <th>Vigencia</th>
                            <th>Estado asignación</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="list-code">@item.CodigoRutaEstudiante</span></td>
                                <td>@item.Ruta?.Nombre</td>
                                <td>@($"{item.Estudiante?.Nombres} {item.Estudiante?.ApellidoPaterno}".Trim())</td>
                                <td>@item.FechaInicioVigencia.ToString("dd/MM/yyyy") - @(item.FechaFinVigencia?.ToString("dd/MM/yyyy") ?? "Vigente")</td>
                                <td><span class="badge @(item.EstadoAsignacion == "ACTIVO" ? "text-bg-info" : "text-bg-secondary")">@item.EstadoAsignacion</span></td>
                                <td><span class="badge @(item.Estado ? "text-bg-success" : "text-bg-secondary")">@(item.Estado ? "Activo" : "Inactivo")</span></td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-1">
                                        <a asp-action="Editar" asp-route-id="@item.IdRutaEstudiante" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil-square"></i></a>
                                        <form asp-action="Eliminar" asp-route-id="@item.IdRutaEstudiante" method="post" class="d-inline form-eliminar" data-confirm data-confirm-title="¿Estás seguro?" data-confirm-text="Esta acción eliminará la asignación seleccionada." data-confirm-icon="warning" data-confirm-confirm-text="Sí, eliminar" data-confirm-cancel-text="Cancelar">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            @await Html.PartialAsync("_ListEmptyState", ("Sin asignaciones", "No hay asignaciones registradas.", "bi-diagram-3"))
        }
    </div>
</div>
