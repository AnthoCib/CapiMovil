@model List<CapiMovil.BL.BE.IncidenciaBE>

@{
    ViewData["Title"] = "Incidencias";

    int total = Model?.Count ?? 0;
    int pendientes = Model?.Count(x => x.EstadoIncidencia == "PENDIENTE") ?? 0;
    int atendidas = Model?.Count(x => x.EstadoIncidencia == "ATENDIDA") ?? 0;
    int cerradas = Model?.Count(x => x.EstadoIncidencia == "CERRADA") ?? 0;
    int criticas = Model?.Count(x => x.Prioridad == "CRITICA") ?? 0;
}

<div class="container-fluid py-3">

    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Gestión de Incidencias</h2>
            <p class="text-muted mb-0">Consulta, registra y administra las incidencias operativas.</p>
        </div>
        <div>
            <a asp-action="Crear" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle me-1"></i> Nueva Incidencia
            </a>
        </div>
    </div>

    @if (TempData["ok"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            @TempData["ok"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Total</div>
                    <div class="fs-3 fw-bold">@total</div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Pendientes</div>
                    <div class="fs-3 fw-bold text-warning">@pendientes</div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Atendidas</div>
                    <div class="fs-3 fw-bold text-primary">@atendidas</div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Cerradas</div>
                    <div class="fs-3 fw-bold text-success">@cerradas</div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Críticas</div>
                    <div class="fs-3 fw-bold text-danger">@criticas</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 py-3">
            <h5 class="mb-0 fw-semibold">Listado General</h5>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Código</th>
                            <th>Recorrido</th>
                            <th>Conductor</th>
                            <th>Tipo</th>
                            <th>Descripción</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                            <th>Prioridad</th>
                            <th class="text-center" style="width: 260px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="fw-semibold">@item.CodigoIncidencia</span>
                                    </td>
                                    <td>@item.CodigoRecorrido</td>
                                    <td>@item.NombreConductor</td>
                                    <td>
                                        <span class="badge rounded-pill bg-dark-subtle text-dark">
                                            @item.TipoIncidencia
                                        </span>
                                    </td>
                                    <td style="max-width: 260px;">
                                        <span class="text-truncate d-inline-block" style="max-width: 240px;" title="@item.Descripcion">
                                            @item.Descripcion
                                        </span>
                                    </td>
                                    <td>@item.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (item.EstadoIncidencia == "PENDIENTE")
                                        {
                                            <span class="badge rounded-pill bg-warning text-dark px-3 py-2">PENDIENTE</span>
                                        }
                                        else if (item.EstadoIncidencia == "ATENDIDA")
                                        {
                                            <span class="badge rounded-pill bg-primary px-3 py-2">ATENDIDA</span>
                                        }
                                        else if (item.EstadoIncidencia == "CERRADA")
                                        {
                                            <span class="badge rounded-pill bg-success px-3 py-2">CERRADA</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-secondary px-3 py-2">@item.EstadoIncidencia</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Prioridad == "CRITICA")
                                        {
                                            <span class="badge rounded-pill bg-danger px-3 py-2">CRÍTICA</span>
                                        }
                                        else if (item.Prioridad == "ALTA")
                                        {
                                            <span class="badge rounded-pill bg-warning text-dark px-3 py-2">ALTA</span>
                                        }
                                        else if (item.Prioridad == "MEDIA")
                                        {
                                            <span class="badge rounded-pill bg-info text-dark px-3 py-2">MEDIA</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-secondary px-3 py-2">BAJA</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex flex-wrap gap-1 justify-content-center">
                                            <a asp-action="Detalle" asp-route-id="@item.IdIncidencia" class="btn btn-outline-info btn-sm">
                                                Ver
                                            </a>

                                            @if (item.EstadoIncidencia != "CERRADA")
                                            {
                                                <button type="button"
                                                        class="btn btn-outline-success btn-sm"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#modalCerrar_@item.IdIncidencia">
                                                    Cerrar
                                                </button>
                                            }

                                            <form asp-action="Eliminar" method="post" class="d-inline form-eliminar">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.IdIncidencia" />
                                                <button type="submit"
                                                        class="btn btn-outline-danger btn-sm">
                                                    <i class="bi bi-trash"></i> Eliminar
                                                </button>
                                            </form>
                                         
                                        </div>
                                    </td>
                                </tr>

                                @if (item.EstadoIncidencia != "CERRADA")
                                {
                                    <div class="modal fade" id="modalCerrar_@item.IdIncidencia" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content border-0 shadow">
                                                <form asp-action="Cerrar" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Cerrar Incidencia</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <input type="hidden" name="id" value="@item.IdIncidencia" />
                                                        <div class="mb-3">
                                                            <label class="form-label fw-semibold">Solución</label>
                                                            <textarea name="solucion" class="form-control" rows="4" required></textarea>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Cancelar</button>
                                                        <button type="submit" class="btn btn-success">Cerrar incidencia</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center py-4">
                                    <div class="text-muted">
                                        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                        No hay incidencias registradas.
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>