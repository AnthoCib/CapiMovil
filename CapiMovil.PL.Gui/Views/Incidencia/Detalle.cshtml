@model CapiMovil.BL.BE.IncidenciaBE

@{
    ViewData["Title"] = "Detalle de Incidencia";
}

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Detalle de Incidencia</h2>
            <p class="text-muted mb-0">Consulta la información completa de la incidencia registrada.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Listar" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-semibold">Resumen</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="text-muted small">Código</div>
                        <div class="fw-semibold">@Model.CodigoIncidencia</div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">Estado</div>
                        <div>
                            @if (Model.EstadoIncidencia == "PENDIENTE")
                            {
                                <span class="badge rounded-pill bg-warning text-dark px-3 py-2">PENDIENTE</span>
                            }
                            else if (Model.EstadoIncidencia == "ATENDIDA")
                            {
                                <span class="badge rounded-pill bg-primary px-3 py-2">ATENDIDA</span>
                            }
                            else if (Model.EstadoIncidencia == "CERRADA")
                            {
                                <span class="badge rounded-pill bg-success px-3 py-2">CERRADA</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-secondary px-3 py-2">@Model.EstadoIncidencia</span>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">Prioridad</div>
                        <div>
                            @if (Model.Prioridad == "CRITICA")
                            {
                                <span class="badge rounded-pill bg-danger px-3 py-2">CRÍTICA</span>
                            }
                            else if (Model.Prioridad == "ALTA")
                            {
                                <span class="badge rounded-pill bg-warning text-dark px-3 py-2">ALTA</span>
                            }
                            else if (Model.Prioridad == "MEDIA")
                            {
                                <span class="badge rounded-pill bg-info text-dark px-3 py-2">MEDIA</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-secondary px-3 py-2">BAJA</span>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">Fecha y hora</div>
                        <div class="fw-semibold">@Model.FechaHora.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>

                    <div>
                        <div class="text-muted small">Fecha de cierre</div>
                        <div class="fw-semibold">
                            @(Model.FechaCierre.HasValue? Model.FechaCierre.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-semibold">Información General</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="text-muted small">Recorrido</div>
                            <div class="fw-semibold">@Model.CodigoRecorrido</div>
                        </div>

                        <div class="col-md-6">
                            <div class="text-muted small">Conductor</div>
                            <div class="fw-semibold">@Model.NombreConductor</div>
                        </div>

                        <div class="col-md-6">
                            <div class="text-muted small">Reportado por</div>
                            <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.UsernameReportadoPor) ? Model.UsernameReportadoPor : "-")</div>
                        </div>

                        <div class="col-md-6">
                            <div class="text-muted small">Tipo</div>
                            <div class="fw-semibold">@Model.TipoIncidencia</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-semibold">Descripción</h5>
                </div>
                <div class="card-body">
                    <p class="mb-0">@Model.Descripcion</p>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-semibold">Solución</h5>
                </div>
                <div class="card-body">
                    @if (string.IsNullOrWhiteSpace(Model.Solucion))
                    {
                        <span class="text-muted">Aún no se ha registrado una solución.</span>
                    }
                    else
                    {
                        <p class="mb-0">@Model.Solucion</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
