@model CapiMovil.PL.Gui.Models.ViewModels.EstudianteFormViewModel

@{
    ViewData["Title"] = "Editar Estudiante";
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
          crossorigin="" />
}

<div class="row g-4">
    <div class="col-xl-8">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h2 class="h4 fw-bold mb-1"><i class="bi bi-person-lines-fill text-primary me-2"></i>Editar estudiante</h2>
                <p class="text-muted mb-0">Actualiza la información personal y académica.</p>
            </div>
            <div class="card-body">
                <form asp-action="Editar" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="IdEstudiante" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="IdPadre" class="form-label"></label>
                            <select asp-for="IdPadre" asp-items="Model.Padres" class="form-select">
                                <option value="">Seleccione un padre</option>
                            </select>
                            <span asp-validation-for="IdPadre" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CodigoEstudiante" class="form-label"></label>
                            <input asp-for="CodigoEstudiante" class="form-control bg-light" readonly />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Nombres" class="form-label"></label>
                            <input asp-for="Nombres" class="form-control" />
                            <span asp-validation-for="Nombres" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ApellidoPaterno" class="form-label"></label>
                            <input asp-for="ApellidoPaterno" class="form-control" />
                            <span asp-validation-for="ApellidoPaterno" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ApellidoMaterno" class="form-label"></label>
                            <input asp-for="ApellidoMaterno" class="form-control" />
                            <span asp-validation-for="ApellidoMaterno" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="DNI" class="form-label"></label>
                            <input asp-for="DNI" class="form-control" />
                            <span asp-validation-for="DNI" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FechaNacimiento" class="form-label"></label>
                            <input asp-for="FechaNacimiento" class="form-control" />
                            <span asp-validation-for="FechaNacimiento" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Genero" class="form-label"></label>
                            <select asp-for="Genero" asp-items="Model.Generos" class="form-select">
                                <option value="">Seleccione</option>
                            </select>
                            <span asp-validation-for="Genero" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Grado" class="form-label"></label>
                            <input asp-for="Grado" class="form-control" />
                            <span asp-validation-for="Grado" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Seccion" class="form-label"></label>
                            <input asp-for="Seccion" class="form-control" />
                            <span asp-validation-for="Seccion" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Direccion" class="form-label"></label>
                            <input asp-for="Direccion" class="form-control" />
                            <span asp-validation-for="Direccion" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="FotoUrl" class="form-label"></label>
                            <input asp-for="FotoUrl" class="form-control" />
                            <span asp-validation-for="FotoUrl" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Observaciones" class="form-label"></label>
                            <textarea asp-for="Observaciones" class="form-control" rows="2"></textarea>
                            <span asp-validation-for="Observaciones" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-check form-switch my-4">
                        <input asp-for="Estado" class="form-check-input" />
                        <label asp-for="Estado" class="form-check-label"></label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Actualizar</button>
                        <a asp-action="Listar" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h3 class="h5 fw-bold mb-1"><i class="bi bi-geo-alt-fill text-danger me-2"></i>Ubicación de casa</h3>
                <p class="text-muted mb-0">Puedes ajustar coordenadas desde el mapa.</p>
            </div>
            <div class="card-body d-flex flex-column gap-3">
                <button type="button" id="btnGeolocalizarEstudiante" class="btn btn-outline-primary">
                    <i class="bi bi-crosshair me-1"></i>Usar mi ubicación actual
                </button>

                <div id="mapEstudiante" class="capi-map capi-map-sm"></div>

                <span id="infoCoordsEstudiante" class="badge text-bg-light border capi-coords-badge align-self-start">Latitud: -- | Longitud: --</span>

                <div class="row g-2">
                    <div class="col-6">
                        <label asp-for="LatitudCasa" class="form-label"></label>
                        <input asp-for="LatitudCasa" class="form-control" step="any" />
                        <span asp-validation-for="LatitudCasa" class="text-danger"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="LongitudCasa" class="form-label"></label>
                        <input asp-for="LongitudCasa" class="form-control" step="any" />
                        <span asp-validation-for="LongitudCasa" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            CapiMovilMaps.createPointPicker({
                mapId: 'mapEstudiante',
                latInputId: 'LatitudCasa',
                lngInputId: 'LongitudCasa',
                geolocateButtonId: 'btnGeolocalizarEstudiante',
                coordinatesInfoId: 'infoCoordsEstudiante',
                defaultCenter: [-12.046374, -77.042793]
            });
        });
    </script>
}
