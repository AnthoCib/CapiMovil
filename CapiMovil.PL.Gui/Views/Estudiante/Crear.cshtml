@model CapiMovil.PL.Gui.Models.ViewModels.EstudianteFormViewModel

@{
    ViewData["Title"] = "Crear Estudiante";
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card card-soft">
            <div class="card-body">
                <h2 class="page-title mb-4">Crear Estudiante</h2>

                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="IdPadre" class="form-label"></label>
                        <select asp-for="IdPadre" asp-items="Model.Padres" class="form-select">
                            <option value="">Seleccione un padre</option>
                        </select>
                        <span asp-validation-for="IdPadre" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CodigoEstudiante" class="form-label"></label>
                        <input asp-for="CodigoEstudiante" class="form-control" />
                        <span asp-validation-for="CodigoEstudiante" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Nombres" class="form-label"></label>
                        <input asp-for="Nombres" class="form-control" />
                        <span asp-validation-for="Nombres" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ApellidoPaterno" class="form-label"></label>
                            <input asp-for="ApellidoPaterno" class="form-control" />
                            <span asp-validation-for="ApellidoPaterno" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="ApellidoMaterno" class="form-label"></label>
                            <input asp-for="ApellidoMaterno" class="form-control" />
                            <span asp-validation-for="ApellidoMaterno" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="DNI" class="form-label"></label>
                            <input asp-for="DNI" class="form-control" />
                            <span asp-validation-for="DNI" class="text-danger"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="FechaNacimiento" class="form-label"></label>
                            <input asp-for="FechaNacimiento" class="form-control" />
                            <span asp-validation-for="FechaNacimiento" class="text-danger"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="Genero" class="form-label"></label>
                            <select asp-for="Genero" asp-items="Model.Generos" class="form-select">
                                <option value="">Seleccione</option>
                            </select>
                            <span asp-validation-for="Genero" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Grado" class="form-label"></label>
                            <input asp-for="Grado" class="form-control" />
                            <span asp-validation-for="Grado" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Seccion" class="form-label"></label>
                            <input asp-for="Seccion" class="form-control" />
                            <span asp-validation-for="Seccion" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Direccion" class="form-label"></label>
                        <input asp-for="Direccion" class="form-control" />
                        <span asp-validation-for="Direccion" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="LatitudCasa" class="form-label"></label>
                            <input asp-for="LatitudCasa" class="form-control" />
                            <span asp-validation-for="LatitudCasa" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="LongitudCasa" class="form-label"></label>
                            <input asp-for="LongitudCasa" class="form-control" />
                            <span asp-validation-for="LongitudCasa" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FotoUrl" class="form-label"></label>
                        <input asp-for="FotoUrl" class="form-control" />
                        <span asp-validation-for="FotoUrl" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Observaciones" class="form-label"></label>
                        <textarea asp-for="Observaciones" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Observaciones" class="text-danger"></span>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input asp-for="Estado" class="form-check-input" />
                        <label asp-for="Estado" class="form-check-label"></label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Guardar</button>
                        <a asp-action="Listar" class="btn btn-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}