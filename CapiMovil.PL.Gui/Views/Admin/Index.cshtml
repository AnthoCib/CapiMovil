@model CapiMovil.PL.Gui.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard Admin";
}

<div class="admin-dashboard-shell">
    <div class="card border-0 shadow-sm admin-welcome mb-3 mb-xl-4">
        <div class="card-body p-4 p-lg-5">
            <h1 class="fw-bold mb-2 app-section-title">@Model.Saludo, Administrador</h1>
            <p class="app-section-subtitle mb-0">Este es el resumen ejecutivo de la operación diaria de transporte escolar.</p>
        </div>
    </div>

    <div class="row g-3 mb-3 mb-xl-4">
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="admin-metric card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="admin-metric-title">Rutas activas</span>
                        <i class="bi bi-signpost-2 admin-icon amber"></i>
                    </div>
                    <div class="admin-metric-value">@Model.TotalRutasActivas</div>
                    <span class="badge rounded-pill text-bg-light">Operativas hoy</span>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="admin-metric card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="admin-metric-title">Estudiantes</span>
                        <i class="bi bi-mortarboard admin-icon sky"></i>
                    </div>
                    <div class="admin-metric-value">@Model.TotalEstudiantes</div>
                    <span class="badge rounded-pill text-bg-light">Activos registrados</span>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="admin-metric card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="admin-metric-title">Conductores</span>
                        <i class="bi bi-person-badge admin-icon mint"></i>
                    </div>
                    <div class="admin-metric-value">@Model.TotalConductoresActivos</div>
                    <span class="badge rounded-pill text-bg-light">Disponibles</span>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="admin-metric card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="admin-metric-title">Incidencias activas</span>
                        <i class="bi bi-exclamation-triangle admin-icon soft-red"></i>
                    </div>
                    <div class="admin-metric-value">@Model.TotalIncidenciasActivas</div>
                    <span class="badge rounded-pill text-bg-light">Requieren atención</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm admin-analytics h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 fw-bold mb-0">Resumen operativo</h2>
                        <a asp-controller="Recorrido" asp-action="Listar" class="btn btn-sm btn-outline-dark rounded-pill px-3"><i class="bi bi-arrow-right-circle me-1"></i>Ver detalle</a>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-6 col-md-3"><div class="admin-kpi"><span>Recorridos en curso</span><strong>@Model.TotalRecorridosEnCurso</strong></div></div>
                        <div class="col-6 col-md-3"><div class="admin-kpi"><span>Notificaciones pendientes</span><strong>@Model.TotalNotificacionesPendientes</strong></div></div>
                        <div class="col-6 col-md-3"><div class="admin-kpi"><span>Buses activos</span><strong>@Model.TotalBusesActivos</strong></div></div>
                        <div class="col-6 col-md-3"><div class="admin-kpi"><span>Usuarios activos</span><strong>@Model.TotalUsuariosActivos</strong></div></div>
                    </div>

                    <div class="admin-chart-placeholder">
                        <div class="admin-chart-bars">
                            <span style="height:44%"></span>
                            <span style="height:65%"></span>
                            <span style="height:52%"></span>
                            <span style="height:78%"></span>
                            <span style="height:60%"></span>
                            <span style="height:85%"></span>
                            <span style="height:70%"></span>
                        </div>
                        <div class="small text-muted mt-2">Actividad operativa semanal (visual referencial).</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm admin-activity h-100">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">Actividad reciente</h2>

                    @if (!Model.ActividadReciente.Any())
                    {
                        <div class="text-muted">Sin actividad reciente para mostrar.</div>
                    }
                    else
                    {
                        <div class="admin-activity-list">
                            @foreach (var item in Model.ActividadReciente)
                            {
                                <div class="admin-activity-item">
                                    <div class="admin-activity-icon @item.Tipo"><i class="bi @item.Icono"></i></div>
                                    <div>
                                        <div class="fw-semibold small">@item.Titulo</div>
                                        <div class="text-muted small">@item.Descripcion</div>
                                        <div class="text-muted x-small">@item.FechaTexto</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
