@model CapiMovil.PL.Gui.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard Admin";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
}

<div class="admin-dashboard-shell">
    <div class="row g-3 g-xl-4">
        <aside class="col-12 col-xl-3 col-xxl-2">
            <div class="admin-side card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column p-3 p-lg-4">
                    <div class="admin-brand mb-4">
                        <div class="admin-brand-icon"><i class="bi bi-bus-front-fill"></i></div>
                        <div>
                            <div class="admin-brand-title">CapiMovil</div>
                            <small class="text-muted">Panel Administrativo</small>
                        </div>
                    </div>

                    <nav class="nav flex-column gap-2 admin-nav mb-4">
                        <a asp-controller="Admin" asp-action="Index" class="nav-link active"><i class="bi bi-grid-1x2-fill"></i>Dashboard</a>
                        <a asp-controller="Estudiante" asp-action="Listar" class="nav-link"><i class="bi bi-mortarboard"></i>Estudiantes</a>
                        <a asp-controller="Conductor" asp-action="Listar" class="nav-link"><i class="bi bi-person-badge"></i>Conductores</a>
                        <a asp-controller="Ruta" asp-action="Listar" class="nav-link"><i class="bi bi-signpost-2"></i>Rutas</a>
                        <a asp-controller="Bus" asp-action="Listar" class="nav-link"><i class="bi bi-bus-front"></i>Buses</a>
                        <a asp-controller="Paradero" asp-action="Listar" class="nav-link"><i class="bi bi-geo-alt"></i>Paraderos</a>
                        <a asp-controller="Recorrido" asp-action="Listar" class="nav-link"><i class="bi bi-map"></i>Seguimiento</a>
                        <a asp-controller="Incidencia" asp-action="Listar" class="nav-link"><i class="bi bi-exclamation-triangle"></i>Incidencias</a>
                        <a asp-controller="Notificacion" asp-action="Listar" class="nav-link"><i class="bi bi-bell"></i>Notificaciones</a>
                    </nav>

                    <a asp-controller="Recorrido" asp-action="Listar" class="btn btn-admin-highlight mt-auto">
                        <i class="bi bi-broadcast-pin me-2"></i>Seguimiento en vivo
                    </a>
                </div>
            </div>
        </aside>

        <section class="col-12 col-xl-9 col-xxl-10">
            <div class="admin-topbar card border-0 shadow-sm mb-3 mb-xl-4">
                <div class="card-body p-3 p-lg-4 d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                    <div class="input-group admin-search">
                        <span class="input-group-text bg-transparent border-0"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control border-0" placeholder="Buscar módulo o acción..." />
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="btn btn-light rounded-circle position-relative"><i class="bi bi-bell"></i><span class="admin-dot"></span></span>
                        <span class="btn btn-light rounded-circle"><i class="bi bi-gear"></i></span>
                        <div class="admin-user-pill">
                            <i class="bi bi-person-circle"></i>
                            <span>Administrador</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm admin-welcome mb-3 mb-xl-4">
                <div class="card-body p-4 p-lg-5">
                    <h1 class="fw-bold mb-2">@Model.Saludo, Administrador</h1>
                    <p class="text-muted mb-0">Este es el resumen ejecutivo de la operación diaria de transporte escolar.</p>
                </div>
            </div>

            <div class="row g-3 mb-3 mb-xl-4">
                <div class="col-12 col-sm-6 col-lg-3">
                    <div class="admin-metric card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="admin-metric-title">Rutas activas</span>
                                <i class="bi bi-signpost-2 admin-icon amber"></i>
                            </div>
                            <div class="admin-metric-value">@Model.TotalRutasActivas</div>
                            <span class="badge rounded-pill text-bg-light">Operativas hoy</span>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-3">
                    <div class="admin-metric card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="admin-metric-title">Estudiantes</span>
                                <i class="bi bi-mortarboard admin-icon sky"></i>
                            </div>
                            <div class="admin-metric-value">@Model.TotalEstudiantes</div>
                            <span class="badge rounded-pill text-bg-light">Activos registrados</span>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-3">
                    <div class="admin-metric card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="admin-metric-title">Conductores</span>
                                <i class="bi bi-person-badge admin-icon mint"></i>
                            </div>
                            <div class="admin-metric-value">@Model.TotalConductoresActivos</div>
                            <span class="badge rounded-pill text-bg-light">Disponibles</span>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-3">
                    <div class="admin-metric card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="admin-metric-title">Incidencias activas</span>
                                <i class="bi bi-exclamation-triangle admin-icon soft-red"></i>
                            </div>
                            <div class="admin-metric-value">@Model.TotalIncidenciasActivas</div>
                            <span class="badge rounded-pill text-bg-light">Requieren atención</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-12 col-lg-8">
                    <div class="card border-0 shadow-sm admin-analytics h-100">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h2 class="h5 fw-bold mb-0">Resumen operativo</h2>
                                <a asp-controller="Recorrido" asp-action="Listar" class="btn btn-sm btn-outline-dark rounded-pill px-3">Ver detalle</a>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-6 col-md-3"><div class="admin-kpi"><span>Recorridos en curso</span><strong>@Model.TotalRecorridosEnCurso</strong></div></div>
                                <div class="col-6 col-md-3"><div class="admin-kpi"><span>Notificaciones pendientes</span><strong>@Model.TotalNotificacionesPendientes</strong></div></div>
                                <div class="col-6 col-md-3"><div class="admin-kpi"><span>Buses activos</span><strong>@Model.TotalBusesActivos</strong></div></div>
                                <div class="col-6 col-md-3"><div class="admin-kpi"><span>Usuarios activos</span><strong>@Model.TotalUsuariosActivos</strong></div></div>
                            </div>

                            <div class="admin-chart-placeholder">
                                <div class="admin-chart-bars">
                                    <span style="height:44%"></span>
                                    <span style="height:65%"></span>
                                    <span style="height:52%"></span>
                                    <span style="height:78%"></span>
                                    <span style="height:60%"></span>
                                    <span style="height:85%"></span>
                                    <span style="height:70%"></span>
                                </div>
                                <div class="small text-muted mt-2">Actividad operativa semanal (visual referencial).</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-4">
                    <div class="card border-0 shadow-sm admin-activity h-100">
                        <div class="card-body p-4">
                            <h2 class="h5 fw-bold mb-3">Actividad reciente</h2>

                            @if (!Model.ActividadReciente.Any())
                            {
                                <div class="text-muted">Sin actividad reciente para mostrar.</div>
                            }
                            else
                            {
                                <div class="admin-activity-list">
                                    @foreach (var item in Model.ActividadReciente)
                                    {
                                        <div class="admin-activity-item">
                                            <div class="admin-activity-icon @item.Tipo"><i class="bi @item.Icono"></i></div>
                                            <div>
                                                <div class="fw-semibold small">@item.Titulo</div>
                                                <div class="text-muted small">@item.Descripcion</div>
                                                <div class="text-muted x-small">@item.FechaTexto</div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>
