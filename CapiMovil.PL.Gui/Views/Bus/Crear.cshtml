@model CapiMovil.PL.Gui.Models.ViewModels.BusFormViewModel

@{
    ViewData["Title"] = "Registrar Bus";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card card-soft">
            <div class="card-body">
                <h2 class="page-title mb-4">Registrar Bus</h2>

                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Placa" class="form-label"></label>
                            <input asp-for="Placa" class="form-control" />
                            <span asp-validation-for="Placa" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Capacidad" class="form-label"></label>
                            <input asp-for="Capacidad" class="form-control" />
                            <span asp-validation-for="Capacidad" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Marca" class="form-label"></label>
                            <input asp-for="Marca" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Modelo" class="form-label"></label>
                            <input asp-for="Modelo" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Color" class="form-label"></label>
                            <input asp-for="Color" class="form-control" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Anio" class="form-label"></label>
                            <input asp-for="Anio" class="form-control" />
                            <span asp-validation-for="Anio" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="EstadoOperacion" class="form-label"></label>
                            <select asp-for="EstadoOperacion" asp-items="Model.EstadosOperacion" class="form-select"></select>
                            <span asp-validation-for="EstadoOperacion" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 d-flex align-items-end mb-3">
                            <div class="form-check form-switch">
                                <input asp-for="SeguroVigente" class="form-check-input" />
                                <label asp-for="SeguroVigente" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FechaVencimientoSOAT" class="form-label"></label>
                            <input asp-for="FechaVencimientoSOAT" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="FechaRevisionTecnica" class="form-label"></label>
                            <input asp-for="FechaRevisionTecnica" class="form-control" />
                        </div>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input asp-for="Estado" class="form-check-input" />
                        <label asp-for="Estado" class="form-check-label"></label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Guardar</button>
                        <a asp-action="Listar" class="btn btn-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}