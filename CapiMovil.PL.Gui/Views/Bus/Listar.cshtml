@model List<CapiMovil.BL.BE.BusBE>

@{
    ViewData["Title"] = "Lista de Buses";
    int total = Model?.Count ?? 0;
    int activos = Model?.Count(x => x.Estado) ?? 0;
    int segurosVigentes = Model?.Count(x => x.SeguroVigente) ?? 0;
}

<div class="list-shell">
    <div class="list-toolbar mb-4">
        <div>
            <h2 class="list-title mb-1">Lista de Buses</h2>
            <p class="list-subtitle mb-0">Flota de transporte con estado operativo y seguro.</p>
        </div>
        <a asp-action="Crear" class="btn btn-primary list-btn-primary"><i class="bi bi-plus-circle me-1"></i>Nuevo bus</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4"><div class="list-kpi-card"><small>Total de buses</small><strong>@total</strong></div></div>
        <div class="col-md-4"><div class="list-kpi-card"><small>Buses activos</small><strong class="text-success">@activos</strong></div></div>
        <div class="col-md-4"><div class="list-kpi-card"><small>Seguro vigente</small><strong class="text-primary">@segurosVigentes</strong></div></div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-3">
            @foreach (var item in Model.OrderBy(x => x.Placa))
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <article class="list-entity-card h-100">
                        <header class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <div>
                                <div class="list-code">@item.CodigoBus</div>
                                <h3 class="h6 mb-0 mt-2"><i class="bi bi-credit-card-2-front me-1 text-primary"></i>@item.Placa</h3>
                            </div>
                            <span class="badge @(item.Estado ? "text-bg-success" : "text-bg-secondary")">@(item.Estado ? "ACTIVO" : "INACTIVO")</span>
                        </header>

                        <div class="list-meta-grid mb-3">
                            <div><small>Marca / Modelo</small><strong>@($"{item.Marca} {item.Modelo}")</strong></div>
                            <div><small>Capacidad</small><strong><i class="bi bi-people me-1"></i>@item.Capacidad pasajeros</strong></div>
                            <div>
                                <small>Estado operativo</small>
                                <strong><span class="badge text-bg-info">@item.EstadoOperacion</span></strong>
                            </div>
                            <div>
                                <small>Seguro</small>
                                <strong><span class="badge @(item.SeguroVigente ? "text-bg-success" : "text-bg-danger")">@(item.SeguroVigente ? "VIGENTE" : "NO VIGENTE")</span></strong>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-2 justify-content-end mt-auto">
                            <a asp-action="Editar" asp-route-id="@item.IdBus" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil-square me-1"></i>Editar</a>
                            <form asp-action="Eliminar" asp-route-id="@item.IdBus" method="post" class="d-inline form-eliminar" data-confirm data-confirm-title="¿Estás seguro?" data-confirm-text="Esta acción eliminará el bus seleccionado." data-confirm-icon="warning" data-confirm-confirm-text="Sí, eliminar" data-confirm-cancel-text="Cancelar">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Eliminar</button>
                            </form>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
    else
    {
        @await Html.PartialAsync("_ListEmptyState", ("Sin buses", "No hay buses registrados.", "bi-bus-front"))
    }
</div>
