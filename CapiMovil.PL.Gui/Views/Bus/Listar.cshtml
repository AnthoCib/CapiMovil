@model List<CapiMovil.BL.BE.BusBE>

@{
    ViewData["Title"] = "Lista de Buses";
}

<div class="list-shell">
    <div class="list-toolbar mb-4">
        <div>
            <h2 class="list-title mb-1">Lista de Buses</h2>
            <p class="list-subtitle mb-0">Flota de transporte con estado operativo y seguro.</p>
        </div>
        <a asp-action="Crear" class="btn btn-primary list-btn-primary"><i class="bi bi-plus-circle me-1"></i>Nuevo bus</a>
    </div>

    <div class="list-table-card">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table list-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Placa</th>
                            <th>Marca/Modelo</th>
                            <th>Capacidad</th>
                            <th>Operación</th>
                            <th>Seguro</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="list-code">@item.CodigoBus</span></td>
                                <td>@item.Placa</td>
                                <td>@($"{item.Marca} {item.Modelo}")</td>
                                <td>@item.Capacidad</td>
                                <td><span class="badge text-bg-info">@item.EstadoOperacion</span></td>
                                <td><span class="badge @(item.SeguroVigente ? "text-bg-success" : "text-bg-danger")">@(item.SeguroVigente ? "Vigente" : "No vigente")</span></td>
                                <td><span class="badge @(item.Estado ? "text-bg-success" : "text-bg-secondary")">@(item.Estado ? "Activo" : "Inactivo")</span></td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-1">
                                        <a asp-action="Editar" asp-route-id="@item.IdBus" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil-square"></i></a>
                                        <form asp-action="Eliminar" asp-route-id="@item.IdBus" method="post" class="d-inline form-eliminar" data-confirm data-confirm-title="¿Estás seguro?" data-confirm-text="Esta acción eliminará el bus seleccionado." data-confirm-icon="warning" data-confirm-confirm-text="Sí, eliminar" data-confirm-cancel-text="Cancelar">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            @await Html.PartialAsync("_ListEmptyState", ("Sin buses", "No hay buses registrados.", "bi-bus-front"))
        }
    </div>
</div>
