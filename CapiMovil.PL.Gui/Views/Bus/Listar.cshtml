@model List<CapiMovil.BL.BE.BusBE>

@{
    ViewData["Title"] = "Lista de Buses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0">Lista de Buses</h2>
    <a asp-action="Crear" class="btn btn-primary">Nuevo Bus</a>
</div>

<div class="card card-soft">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Placa</th>
                        <th>Marca / Modelo</th>
                        <th>Capacidad</th>
                        <th>Estado Operativo</th>
                        <th>Seguro</th>
                        <th>Estado</th>
                        <th style="width:160px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.CodigoBus</td>
                                <td>@item.Placa</td>
                                <td>@($"{item.Marca} {item.Modelo}")</td>
                                <td>@item.Capacidad</td>
                                <td>
                                    <span class="badge bg-info">@item.EstadoOperacion</span>
                                </td>
                                <td>
                                    @if (item.SeguroVigente)
                                    {
                                        <span class="badge bg-success">Vigente</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">No vigente</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Estado)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Editar" asp-route-id="@item.IdBus" class="btn btn-warning btn-sm">Editar</a>

                                    <form asp-action="Eliminar" asp-route-id="@item.IdBus" method="post" class="d-inline form-eliminar">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            Eliminar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">No hay buses registrados.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>