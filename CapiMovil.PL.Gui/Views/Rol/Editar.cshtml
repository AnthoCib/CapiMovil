@model CapiMovil.BL.BE.RolBE

@{
    ViewData["Title"] = "Editar Rol";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning">
                    <h4 class="mb-0">Editar Rol</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Editar" method="post">
                        @Html.AntiForgeryToken()

                        <input asp-for="IdRol" type="hidden" />
                        <input asp-for="CodigoRol" type="hidden" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label">Código</label>
                            <input class="form-control" value="@Model.CodigoRol" disabled />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label">Nombre del Rol</label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>

                        <div class="form-check form-switch mb-3">
                            <input asp-for="Estado" class="form-check-input" />
                            <label asp-for="Estado" class="form-check-label">Activo</label>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Listar" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Volver
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-save"></i> Actualizar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}