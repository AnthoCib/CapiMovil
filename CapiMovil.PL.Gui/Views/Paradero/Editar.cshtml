@model CapiMovil.PL.Gui.Models.ViewModels.ParaderoFormViewModel

@{
    ViewData["Title"] = "Editar Paradero";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card card-soft">
            <div class="card-body">
                <h2 class="page-title mb-4">Editar Paradero</h2>

                <form asp-action="Editar" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="IdParadero" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="CodigoParadero" class="form-label"></label>
                        <input asp-for="CodigoParadero" class="form-control" readonly />
                    </div>

                    <div class="mb-3">
                        <label asp-for="IdRuta" class="form-label"></label>
                        <select asp-for="IdRuta" asp-items="Model.Rutas" class="form-select">
                            <option value="">Seleccione una ruta</option>
                        </select>
                        <span asp-validation-for="IdRuta" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Direccion" class="form-label"></label>
                        <input asp-for="Direccion" class="form-control" />
                        <span asp-validation-for="Direccion" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Latitud" class="form-label"></label>
                            <input asp-for="Latitud" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Longitud" class="form-label"></label>
                            <input asp-for="Longitud" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="OrdenParada" class="form-label"></label>
                            <input asp-for="OrdenParada" class="form-control" />
                            <span asp-validation-for="OrdenParada" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="HoraEstimada" class="form-label"></label>
                        <input asp-for="HoraEstimada" class="form-control" />
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input asp-for="Estado" class="form-check-input" />
                        <label asp-for="Estado" class="form-check-label"></label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Actualizar</button>
                        <a asp-action="Listar" class="btn btn-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}