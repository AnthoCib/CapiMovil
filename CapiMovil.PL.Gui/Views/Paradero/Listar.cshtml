@model List<CapiMovil.BL.BE.ParaderoBE>

@{
    ViewData["Title"] = "Lista de Paraderos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0">Lista de Paraderos</h2>
    <a asp-action="Crear" class="btn btn-primary">Nuevo Paradero</a>
</div>

<div class="card card-soft">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Ruta</th>
                        <th>Nombre</th>
                        <th>Dirección</th>
                        <th>Orden</th>
                        <th>Hora Estimada</th>
                        <th>Estado</th>
                        <th style="width:160px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.CodigoParadero</td>
                                <td>@item.Ruta?.Nombre</td>
                                <td>@item.Nombre</td>
                                <td>@item.Direccion</td>
                                <td>@item.OrdenParada</td>
                                <td>@(item.HoraEstimada?.ToString(@"hh\:mm") ?? "-")</td>
                                <td>
                                    @if (item.Estado)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Editar" asp-route-id="@item.IdParadero" class="btn btn-warning btn-sm">Editar</a>

                                    <form asp-action="Eliminar" asp-route-id="@item.IdParadero" method="post" class="d-inline form-eliminar">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm"
                                                onclick="return confirm('¿Desea eliminar este paradero?');">
                                            Eliminar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">No hay paraderos registrados.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>