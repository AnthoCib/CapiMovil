@model CapiMovil.PL.Gui.Models.ViewModels.EventoAbordajeFormViewModel

@{
    ViewData["Title"] = "Registrar Evento";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card card-soft h-100">
            <div class="card-body">
                <h2 class="page-title mb-4">Registrar Evento de Abordaje</h2>

                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="IdRecorrido" class="form-label"></label>
                            <select asp-for="IdRecorrido" asp-items="Model.Recorridos" class="form-select">
                                <option value="">Seleccione un recorrido</option>
                            </select>
                            <span asp-validation-for="IdRecorrido" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="IdEstudiante" class="form-label"></label>
                            <select asp-for="IdEstudiante" asp-items="Model.Estudiantes" class="form-select">
                                <option value="">Seleccione un estudiante</option>
                            </select>
                            <span asp-validation-for="IdEstudiante" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="IdParadero" class="form-label"></label>
                            <select asp-for="IdParadero" asp-items="Model.Paraderos" class="form-select">
                                <option value="">Seleccione un paradero</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TipoEvento" class="form-label"></label>
                            <select asp-for="TipoEvento" asp-items="Model.TiposEvento" class="form-select"></select>
                            <span asp-validation-for="TipoEvento" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="FechaHora" class="form-label"></label>
                            <input asp-for="FechaHora" class="form-control" readonly />
                            <small class="text-muted">Se registra automáticamente al guardar.</small>
                        </div>

                        <div class="col-12">
                            <label asp-for="Observacion" class="form-label"></label>
                            <textarea asp-for="Observacion" class="form-control"></textarea>
                        </div>

                        <div class="col-12">
                            <div class="form-check form-switch mb-0">
                                <input asp-for="Estado" class="form-check-input" />
                                <label asp-for="Estado" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Guardar</button>
                        <a asp-action="Listar" class="btn btn-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card card-soft h-100">
            <div class="card-body">
                <h3 class="h6">Reglas operativas</h3>
                <ul class="small text-muted ps-3 mb-0">
                    <li>Solo conductores autorizados pueden registrar eventos.</li>
                    <li>La fecha/hora se genera automáticamente al enviar.</li>
                    <li>Use SUBIDA/BAJADA según el flujo real del recorrido.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
