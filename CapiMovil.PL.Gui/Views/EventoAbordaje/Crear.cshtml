@model CapiMovil.PL.Gui.Models.ViewModels.ConductorAbordajeOperacionViewModel

@{
    ViewData["Title"] = "Operación de Abordajes";
}

<div class="abordaje-operacion-page">
    <section class="card card-soft mb-3">
        <div class="card-body">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div>
                    <h2 class="page-title mb-1">Centro de Abordajes</h2>
                    <p class="text-muted mb-0">Registro rápido por alumno con estado operativo en tiempo real.</p>
                </div>
                <form asp-action="Crear" method="get" class="d-flex flex-wrap gap-2">
                    <select name="idRecorrido" class="form-select form-select-sm abordaje-filter-control" onchange="this.form.submit()">
                        <option value="">Seleccione recorrido</option>
                        @foreach (var item in Model.Recorridos)
                        {
                            <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                        }
                    </select>
                    <select name="idParadero" class="form-select form-select-sm abordaje-filter-control" onchange="this.form.submit()">
                        @foreach (var item in Model.ParaderosFiltro)
                        {
                            <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                        }
                    </select>
                    <select name="estado" class="form-select form-select-sm abordaje-filter-control" onchange="this.form.submit()">
                        @foreach (var item in Model.EstadosFiltro)
                        {
                            <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                        }
                    </select>
                </form>
            </div>

            <div class="abordaje-head-grid mt-3">
                <div><small>Recorrido</small><strong>@Model.CodigoRecorrido</strong></div>
                <div><small>Ruta</small><strong>@Model.Ruta</strong></div>
                <div><small>Bus</small><strong>@Model.Bus</strong></div>
                <div><small>Conductor</small><strong>@Model.Conductor</strong></div>
                <div><small>Fecha</small><strong>@Model.FechaOperacion.ToString("dd/MM/yyyy")</strong></div>
                <div><small>Estado recorrido</small><strong><span class="badge bg-info text-dark">@Model.EstadoRecorrido</span></strong></div>
                <div><small>Paradero actual</small><strong>@(string.IsNullOrWhiteSpace(Model.ParaderoActual) ? "No determinado" : Model.ParaderoActual)</strong></div>
            </div>
        </div>
    </section>

    <section class="row g-2 mb-3">
        <div class="col-6 col-md-4 col-xl-2"><div class="abordaje-kpi"><small>Total</small><strong>@Model.TotalAlumnos</strong></div></div>
        <div class="col-6 col-md-4 col-xl-2"><div class="abordaje-kpi subio"><small>Subieron</small><strong>@Model.TotalSubieron</strong></div></div>
        <div class="col-6 col-md-4 col-xl-2"><div class="abordaje-kpi bajo"><small>Bajaron</small><strong>@Model.TotalBajaron</strong></div></div>
        <div class="col-6 col-md-4 col-xl-2"><div class="abordaje-kpi pendiente"><small>Pendientes</small><strong>@Model.TotalPendientes</strong></div></div>
        <div class="col-6 col-md-4 col-xl-2"><div class="abordaje-kpi ausente"><small>Ausentes</small><strong>@Model.TotalAusentes</strong></div></div>
        <div class="col-6 col-md-4 col-xl-2"><div class="abordaje-kpi noabordo"><small>No abordó</small><strong>@Model.TotalNoAbordo</strong></div></div>
    </section>

    <section class="card card-soft">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="h5 mb-0">Paraderos operativos</h3>
                <span class="text-muted small">Cada tarjeta agrupa alumnos por paradero y acciones rápidas.</span>
            </div>

            @if (!Model.Paraderos.Any())
            {
                <div class="alert alert-warning mb-0">No hay paraderos/alumnos para el filtro seleccionado.</div>
            }
            else
            {
                <div class="abordaje-paraderos-list">
                    @foreach (var paradero in Model.Paraderos)
                    {
                        <article class="abordaje-paradero-card @(paradero.EsParaderoActual ? "es-actual" : "")">
                            <header class="abordaje-paradero-header">
                                <div>
                                    <h4 class="mb-1">#@paradero.OrdenParada · @paradero.Nombre</h4>
                                    <p class="mb-0 text-muted"><i class="bi bi-geo-alt"></i> @paradero.Direccion</p>
                                </div>
                                <div class="text-end">
                                    @if (paradero.EsParaderoActual)
                                    {
                                        <span class="badge bg-info text-dark mb-1">PARADERO ACTUAL</span>
                                    }
                                    <div class="small text-muted">Hora estimada: @(paradero.HoraEstimada.HasValue ? paradero.HoraEstimada.Value.ToString(@"hh\:mm") : "--:--")</div>
                                    <div class="small text-muted">Alumnos: @paradero.TotalAlumnos</div>
                                </div>
                            </header>

                            <div class="abordaje-paradero-resumen mb-2">
                                <span class="badge text-bg-light">Subieron: @paradero.TotalSubieron</span>
                                <span class="badge text-bg-light">Bajaron: @paradero.TotalBajaron</span>
                                <span class="badge text-bg-light">Pendientes: @paradero.TotalPendientes</span>
                                <span class="badge text-bg-light">Ausentes: @paradero.TotalAusentes</span>
                                <span class="badge text-bg-light">No abordó: @paradero.TotalNoAbordo</span>
                            </div>

                            <div class="abordaje-students-list">
                                @foreach (var alumno in paradero.Alumnos)
                                {
                                    <article class="abordaje-student-card">
                                        <header>
                                            <div>
                                                <h5>@alumno.NombreCompleto</h5>
                                                <p class="mb-0 text-muted">@alumno.CodigoEstudiante · @alumno.GradoSeccion</p>
                                            </div>
                                            <span class="badge @alumno.EstadoBadgeClass">@alumno.EstadoActual</span>
                                        </header>

                                        <div class="abordaje-student-meta">
                                            <span><i class="bi bi-clock-history"></i> @(alumno.UltimoEventoFechaHora.HasValue ? alumno.UltimoEventoFechaHora.Value.ToString("dd/MM HH:mm:ss") : "Sin eventos")</span>
                                        </div>

                                        <div class="abordaje-actions-grid">
                                            <form asp-action="RegistrarRapido" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="idRecorrido" value="@Model.IdRecorridoSeleccionado" />
                                                <input type="hidden" name="idEstudiante" value="@alumno.IdEstudiante" />
                                                <input type="hidden" name="idParadero" value="@alumno.IdParaderoSubida" />
                                                <input type="hidden" name="tipoEvento" value="SUBIDA" />
                                                <input type="hidden" name="idParaderoFiltro" value="@Model.IdParaderoFiltro" />
                                                <input type="hidden" name="estadoFiltro" value="@Model.EstadoFiltro" />
                                                <button class="btn btn-success abordaje-action-btn" type="submit" disabled="@(!alumno.PermiteSubida)">SUBIDA</button>
                                            </form>

                                            <form asp-action="RegistrarRapido" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="idRecorrido" value="@Model.IdRecorridoSeleccionado" />
                                                <input type="hidden" name="idEstudiante" value="@alumno.IdEstudiante" />
                                                <input type="hidden" name="idParadero" value="@alumno.IdParaderoSubida" />
                                                <input type="hidden" name="tipoEvento" value="BAJADA" />
                                                <input type="hidden" name="idParaderoFiltro" value="@Model.IdParaderoFiltro" />
                                                <input type="hidden" name="estadoFiltro" value="@Model.EstadoFiltro" />
                                                <button class="btn btn-primary abordaje-action-btn" type="submit" disabled="@(!alumno.PermiteBajada)">BAJADA</button>
                                            </form>

                                            <form asp-action="RegistrarRapido" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="idRecorrido" value="@Model.IdRecorridoSeleccionado" />
                                                <input type="hidden" name="idEstudiante" value="@alumno.IdEstudiante" />
                                                <input type="hidden" name="idParadero" value="@alumno.IdParaderoSubida" />
                                                <input type="hidden" name="tipoEvento" value="AUSENTE" />
                                                <input type="hidden" name="idParaderoFiltro" value="@Model.IdParaderoFiltro" />
                                                <input type="hidden" name="estadoFiltro" value="@Model.EstadoFiltro" />
                                                <button class="btn btn-danger abordaje-action-btn" type="submit" disabled="@(!alumno.PermiteAusente)">AUSENTE</button>
                                            </form>

                                            <form asp-action="RegistrarRapido" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="idRecorrido" value="@Model.IdRecorridoSeleccionado" />
                                                <input type="hidden" name="idEstudiante" value="@alumno.IdEstudiante" />
                                                <input type="hidden" name="idParadero" value="@alumno.IdParaderoSubida" />
                                                <input type="hidden" name="tipoEvento" value="NO_ABORDO" />
                                                <input type="hidden" name="idParaderoFiltro" value="@Model.IdParaderoFiltro" />
                                                <input type="hidden" name="estadoFiltro" value="@Model.EstadoFiltro" />
                                                <button class="btn btn-dark abordaje-action-btn" type="submit" disabled="@(!alumno.PermiteNoAbordo)">NO ABORDÓ</button>
                                            </form>
                                        </div>
                                    </article>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
